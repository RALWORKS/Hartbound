offset_left = 902.0
offset_top = 29.0
offset_right = 1271.0
offset_bottom = 105.0
text = "\"Oh, I'm very aware."

[node name="SmartLabel2" parent="Concepts/SummerSolstice/SunTemple" index="3" instance=ExtResource("5_p6pbe")]
offset_left = 934.0
offset_top = 118.0
offset_right = 1417.0
offset_bottom = 232.0
text = "\"I thought you'd  be a safe person to tell, because ..."

[node name="SmartLabel3" parent="Concepts/SummerSolstice/SunTemple" index="4" instance=ExtResource("5_p6pbe")]
offset_left = 1006.0
offset_top = 245.0
offset_right = 1631.0
offset_bottom = 408.0
bbcode_enabled = true
text = "... you share this heritage with me. You know what the Saint [i] means[/i], outside of being a Moon Temple battle cry."

[node name="SmartLabel4" parent="Concepts/SummerSolstice/SunTemple" index="5" instance=ExtResource("5_p6pbe")]
offset_left = 769.0
offset_top = 760.0
offset_right = 1061.0
offset_bottom = 838.0
bbcode_enabled = true
text = "\"If I was wrong?"

[node name="SmartLabel5" parent="Concepts/SummerSolstice/SunTemple" index="6" instance=ExtResource("5_p6pbe")]
offset_left = 847.0
offset_top = 855.0
offset_right = 1684.0
offset_bottom = 971.0
bbcode_enabled = true
text = "\"Well in that case, the secret police will be coming to call, won't they?"

[node name="Religion" parent="Concepts/SummerSolstice" index="5" instance=ExtResource("7_roo2l")]
visible = false

