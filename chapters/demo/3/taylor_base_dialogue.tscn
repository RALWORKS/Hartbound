[node name="SmartLabel" parent="Concepts/SummerSolstice/Religion" index="2" instance=ExtResource("5_p6pbe")]
offset_left = 823.0
offset_top = 250.0
offset_right = 958.0
offset_bottom = 327.0
text = "\"Huh."

[node name="SmartLabel2" parent="Concepts/SummerSolstice/Religion" index="3" instance=ExtResource("5_p6pbe")]
offset_left = 845.0
offset_top = 341.0
offset_right = 1436.0
offset_bottom = 501.0
bbcode_enabled = true
text = "\"Well thanks, I guess. Most people here would react a lot worse to a statement like that."

[node name="SmartLabel3" parent="Concepts/SummerSolstice/Religion" index="4" instance=ExtResource("5_p6pbe")]
offset_left = 965.0
offset_top = 516.0
offset_right = 1556.0
offset_bottom = 644.0
bbcode_enabled = true
text = "\"It's ... surprising to me if that's all this means to you."

[node name="SmartLabel4" parent="Concepts/SummerSolstice/Religion" index="5" instance=ExtResource("5_p6pbe")]
offset_left = 1031.0
offset_top = 658.0
offset_right = 1622.0
offset_bottom = 786.0
bbcode_enabled = true
text = "\"But then, maybe it's more surprising that it still means this much to me."

[node name="SmartLabel5" parent="Concepts/SummerSolstice/Religion" index="6" instance=ExtResource("5_p6pbe")]
offset_left = 847.0
offset_top = 804.0
offset_right = 1694.0
offset_bottom = 885.0
bbcode_enabled = true
text = "\"We've both been away from Moon Temple a long time.\""

