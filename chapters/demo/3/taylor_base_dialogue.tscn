offset_top = 250.0
offset_right = 1414.0
offset_bottom = 403.0
text = "\"Half-human. Hah. It's been a while since I heard that. Really brings back my Moon Temple days--"

[node name="SmartLabel2" parent="Concepts/SummerSolstice/HalfHuman" index="3" instance=ExtResource("5_p6pbe")]
offset_left = 906.0
offset_top = 426.0
offset_right = 1497.0
offset_bottom = 522.0
bbcode_enabled = true
text = "\"You know: [i]my entire childhood.[/i]"

[node name="SmartLabel3" parent="Concepts/SummerSolstice/HalfHuman" index="4" instance=ExtResource("5_p6pbe")]
offset_left = 965.0
offset_top = 547.0
offset_right = 1556.0
offset_bottom = 675.0
bbcode_enabled = true
text = "\"{character,name,full}, bless your [i]true Elven soul--[/i]"

[node name="SmartLabel4" parent="Concepts/SummerSolstice/HalfHuman" index="5" instance=ExtResource("5_p6pbe")]
offset_left = 1031.0
offset_top = 700.0
offset_right = 1622.0
offset_bottom = 828.0
bbcode_enabled = true
text = "\"To everyone in Sun Temple, I am [i]Half Elf.[/i]\""

