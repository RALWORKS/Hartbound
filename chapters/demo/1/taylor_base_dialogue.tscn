[node name="Freeing" parent="ArrivalMemory5" index="7" node_paths=PackedStringArray("to") instance=ExtResource("8_w0od5")]
offset_left = 939.0
offset_top = 746.0
offset_right = 1489.0
offset_bottom = 800.0
