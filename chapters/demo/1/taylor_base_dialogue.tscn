a bit of the same?\""

[node name="Agree" parent="ArrivalMemory5" index="4" node_paths=PackedStringArray("to") instance=ExtResource("8_w0od5")]
offset_left = 939.0
offset_top = 541.0
offset_right = 1489.0
offset_bottom = 595.0
