[node name="SmartLabel4" parent="ArrivalMemory4" index="3" instance=ExtResource("5_sc1vl")]
offset_left = 18.0
offset_top = 17.0
offset_right = 1104.0
offset_bottom = 106.0
text = "\"Twleve years old? My mother was still singing me to sleep at that age."

[node name="SmartLabel6" parent="ArrivalMemory4" index="4" instance=ExtResource("5_sc1vl")]
offset_left = 254.0
offset_top = 117.0
offset_right = 1645.0
offset_bottom = 203.0
text = "\"Then I was sent to my father's people, and suddenly I was too old even to cry of homesickness."

