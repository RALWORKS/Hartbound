offset_left = 757.0
offset_top = 246.0
offset_right = 1283.0
offset_bottom = 335.0
text = "\"Was it just me? Was I just weak?"

[node name="SmartLabel5" parent="ArrivalMemory5" index="3" instance=ExtResource("5_sc1vl")]
offset_left = 801.0
offset_top = 351.0
offset_right = 1333.0
offset_bottom = 473.0
