offset_bottom = 663.0
text = "> \"No. You were just weak."
to = NodePath("../../ArrivalMemoryHurt")

[node name="Distracted" parent="ArrivalMemory5" index="6" node_paths=PackedStringArray("to") instance=ExtResource("8_w0od5")]
offset_left = 939.0
offset_top = 677.0
offset_right = 1489.0
offset_bottom = 731.0
text = "> \"I had a lot on my mind at that time. Can't say that I noticed."
