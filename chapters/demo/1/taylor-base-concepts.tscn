offset_right = 1394.0
offset_bottom = 449.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"They called me [i]Ceyntya[/i] back home."

[node name="RichTextLabel3" type="RichTextLabel" parent="ElvenNames/ElvenName3"]
offset_left = 830.0
offset_top = 465.0
offset_right = 1341.0
offset_bottom = 590.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"You're welcome to do the same. If you want.\""

