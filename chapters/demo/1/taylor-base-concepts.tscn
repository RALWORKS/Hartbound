[node name="taylor2" type="Sprite2D" parent="Brona/Brona1"]
position = Vector2(455, 850)
scale = Vector2(0.7, 0.7)
texture = ExtResource("31_kx3if")

[node name="RichTextLabel" type="RichTextLabel" parent="Brona/Brona1"]
offset_left = 659.0
offset_top = 153.0
offset_right = 978.0
offset_bottom = 273.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"She's grown up a lot, hasn't she?\""

[node name="RichTextLabel2" type="RichTextLabel" parent="Brona/Brona1"]
offset_left = 733.0
offset_top = 289.0
offset_right = 1236.0
offset_bottom = 457.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"Hmm. Maybe it's rude of me to say that when she's only a year or two younger than us.\""

[node name="Brona2" parent="Brona" instance=ExtResource("2_xxf8h")]
visible = false

[node name="bg" type="Sprite2D" parent="Brona/Brona2"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_ao1sr")
centered = false

[node name="taylor2" type="Sprite2D" parent="Brona/Brona2"]
position = Vector2(455, 850)
scale = Vector2(0.7, 0.7)
texture = ExtResource("31_kx3if")

[node name="RichTextLabel" type="RichTextLabel" parent="Brona/Brona2"]
offset_left = 879.0
offset_top = 471.0
offset_right = 1500.0
offset_bottom = 629.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"But growing up with her, I don't know if I'd have guessed she'd be able to find a job that [i]fits[/i] her so well.\""

[node name="RichTextLabel2" type="RichTextLabel" parent="Brona/Brona2"]
offset_left = 1053.0
offset_top = 639.0
offset_right = 1588.0
offset_bottom = 797.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"She was always in trouble, you know? But now? She's made it. I'm happy for her.\""

[node name="Sun Temple" parent="." instance=ExtResource("11_0co5p")]

[node name="SunTemple1" parent="Sun Temple" node_paths=PackedStringArray("next") instance=ExtResource("2_xxf8h")]
visible = false
next = NodePath("../SunTemple2")

[node name="bg" type="Sprite2D" parent="Sun Temple/SunTemple1"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_ao1sr")
centered = false

[node name="taylor2" type="Sprite2D" parent="Sun Temple/SunTemple1"]
position = Vector2(455, 850)
scale = Vector2(0.7, 0.7)
texture = ExtResource("31_kx3if")

[node name="RichTextLabel" type="RichTextLabel" parent="Sun Temple/SunTemple1"]
offset_left = -1.0
offset_top = 875.0
offset_right = 1944.0
offset_bottom = 995.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"You know that's actually an exonym? It's what the Elves call them. I mean, what the Elves call [i]us[/i].\""

[node name="SunTemple2" parent="Sun Temple" node_paths=PackedStringArray("next") instance=ExtResource("2_xxf8h")]
visible = false
next = NodePath("../SunTemple3")

[node name="bg" type="Sprite2D" parent="Sun Temple/SunTemple2"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_ao1sr")
centered = false

[node name="taylor2" type="Sprite2D" parent="Sun Temple/SunTemple2"]
position = Vector2(455, 850)
scale = Vector2(0.7, 0.7)
texture = ExtResource("31_kx3if")

[node name="RichTextLabel" type="RichTextLabel" parent="Sun Temple/SunTemple2"]
offset_left = -1.0
offset_top = 875.0
offset_right = 1944.0
offset_bottom = 995.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"The Elves called [i]us[/i] Sun worshippers for trying to ressurect the Age of the Sun, and when we took
the Moon Temple as our enemy, we wore that accusation as a badge of pride."

[node name="SunTemple3" parent="Sun Temple" instance=ExtResource("2_xxf8h")]
visible = false

[node name="bg" type="Sprite2D" parent="Sun Temple/SunTemple3"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_ao1sr")
centered = false

[node name="taylor2" type="Sprite2D" parent="Sun Temple/SunTemple3"]
position = Vector2(455, 850)
scale = Vector2(0.7, 0.7)
texture = ExtResource("31_kx3if")

[node name="RichTextLabel" type="RichTextLabel" parent="Sun Temple/SunTemple3"]
offset_left = 681.0
offset_top = 173.0
offset_right = 1262.0
offset_bottom = 261.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"[i]Yes,[/i] we're trying to turn back time. "

[node name="RichTextLabel2" type="RichTextLabel" parent="Sun Temple/SunTemple3"]
offset_left = 743.0
offset_top = 277.0
offset_right = 1350.0
offset_bottom = 365.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"[i]Yes,[/i] we're opposing the natural order. "

[node name="RichTextLabel3" type="RichTextLabel" parent="Sun Temple/SunTemple3"]
offset_left = 775.0
offset_top = 383.0
offset_right = 1382.0
offset_bottom = 557.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"[i]Yes,[/i] we're going to make the Sun
rise again, before Night can even fall. [i]That's[/i] the meaning of Sun Temple.\""

[node name="Elves" parent="." instance=ExtResource("12_nnrce")]

[node name="CutsceneNode" parent="Elves" instance=ExtResource("2_xxf8h")]
visible = false

[node name="bg" type="Sprite2D" parent="Elves/CutsceneNode"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_ao1sr")
centered = false

[node name="taylor2" type="Sprite2D" parent="Elves/CutsceneNode"]
position = Vector2(455, 850)
scale = Vector2(0.7, 0.7)
texture = ExtResource("31_kx3if")

[node name="RichTextLabel" type="RichTextLabel" parent="Elves/CutsceneNode"]
offset_left = 742.0
offset_top = 148.0
offset_right = 1395.0
offset_bottom = 263.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"My mother was an Elf. But I've told you that before.\""

[node name="RichTextLabel2" type="RichTextLabel" parent="Elves/CutsceneNode"]
offset_left = 826.0
offset_top = 284.0
offset_right = 1479.0
offset_bottom = 433.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"I'm afraid being Half has coloured my impressions of your people ... in a way that's not wholly positive.\""

[node name="RichTextLabel3" type="RichTextLabel" parent="Elves/CutsceneNode"]
offset_left = 932.0
offset_top = 454.0
offset_right = 1585.0
offset_bottom = 569.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"Even when I was a child at Moon Temple, I was always a bit of an outsider. \""

[node name="Humans" parent="." instance=ExtResource("13_g47my")]

[node name="humans1" parent="Humans" node_paths=PackedStringArray("next") instance=ExtResource("2_xxf8h")]
visible = false
next = NodePath("../humans2")

[node name="bg" type="Sprite2D" parent="Humans/humans1"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_ao1sr")
centered = false

[node name="taylor2" type="Sprite2D" parent="Humans/humans1"]
position = Vector2(481, 868)
scale = Vector2(0.7, 0.7)
texture = ExtResource("13_j3tip")

[node name="RichTextLabel" type="RichTextLabel" parent="Humans/humans1"]
offset_left = 740.0
offset_top = 156.0
offset_right = 1334.0
offset_bottom = 276.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"Humans act like they're the only [i]people[/i] in the world.\""

[node name="humans2" parent="Humans" node_paths=PackedStringArray("next") instance=ExtResource("2_xxf8h")]
visible = false
next = NodePath("../humans3")

[node name="bg" type="Sprite2D" parent="Humans/humans2"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_ao1sr")
centered = false

[node name="taylor2" type="Sprite2D" parent="Humans/humans2"]
position = Vector2(481, 868)
scale = Vector2(0.7, 0.7)
texture = ExtResource("31_kx3if")

[node name="RichTextLabel" type="RichTextLabel" parent="Humans/humans2"]
offset_left = 740.0
offset_top = 156.0
offset_right = 1334.0
offset_bottom = 276.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"Not as if the rest of us aren't people, so much as ... how to put it?"

[node name="humans3" parent="Humans" instance=ExtResource("2_xxf8h")]
visible = false

[node name="bg" type="Sprite2D" parent="Humans/humans3"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_ao1sr")
centered = false

[node name="taylor2" type="Sprite2D" parent="Humans/humans3"]
position = Vector2(481, 868)
scale = Vector2(0.7, 0.7)
texture = ExtResource("13_j3tip")

[node name="RichTextLabel" type="RichTextLabel" parent="Humans/humans3"]
offset_left = 740.0
offset_top = 156.0
offset_right = 1334.0
offset_bottom = 276.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"--That humans are the default people, and everyone else is an exception."

[node name="RichTextLabel2" type="RichTextLabel" parent="Humans/humans3"]
offset_left = 840.0
offset_top = 310.0
offset_right = 1434.0
offset_bottom = 544.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"Elves'll exclude, and patronize, and condescend, but at least they have the awareness--most of the time--that not everybody shares their experience of the world.\""

[node name="MoonTemple" parent="." instance=ExtResource("15_rb8eg")]

[node name="CutsceneNode" parent="MoonTemple" node_paths=PackedStringArray("next") instance=ExtResource("2_xxf8h")]
visible = false
next = NodePath("../CutsceneNode2")

[node name="bg" type="Sprite2D" parent="MoonTemple/CutsceneNode"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_ao1sr")
centered = false

[node name="taylor2" type="Sprite2D" parent="MoonTemple/CutsceneNode"]
position = Vector2(481, 868)
scale = Vector2(0.7, 0.7)
texture = ExtResource("31_kx3if")

[node name="RichTextLabel" type="RichTextLabel" parent="MoonTemple/CutsceneNode"]
offset_left = 861.0
offset_top = 278.0
offset_right = 1485.0
offset_bottom = 441.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"Moon Temple's a lot smaller than Sun Temple, for one thing. I thought I knew what a big city was, but I [i]really[/i] didn't."

[node name="RichTextLabel2" type="RichTextLabel" parent="MoonTemple/CutsceneNode"]
offset_left = 717.0
offset_top = 84.0
offset_right = 1250.0
offset_bottom = 247.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"I only lived there until I was about twelve, but it was quite the culture shock coming here. "

[node name="RichTextLabel3" type="RichTextLabel" parent="MoonTemple/CutsceneNode"]
offset_left = 813.0
offset_top = 473.0
offset_right = 1624.0
offset_bottom = 596.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"It's all Elves, for another. I wouldn't have guessed it would make much difference. People are people, right?"

[node name="RichTextLabel4" type="RichTextLabel" parent="MoonTemple/CutsceneNode"]
offset_left = 816.0
offset_top = 627.0
offset_right = 1627.0
offset_bottom = 809.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"But cultures can have [i]very[/i] different values, and I wish I could have learned that [i]fascinating[/i] truth in a [i]gentler[/i] way.\""

[node name="CutsceneNode2" parent="MoonTemple" node_paths=PackedStringArray("next") instance=ExtResource("2_xxf8h")]
visible = false
next = NodePath("../CutsceneNode3")

[node name="bg" type="Sprite2D" parent="MoonTemple/CutsceneNode2"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_ao1sr")
centered = false

[node name="taylor2" type="Sprite2D" parent="MoonTemple/CutsceneNode2"]
position = Vector2(481, 868)
scale = Vector2(0.7, 0.7)
texture = ExtResource("31_kx3if")

[node name="RichTextLabel" type="RichTextLabel" parent="MoonTemple/CutsceneNode2"]
offset_left = 695.0
offset_top = 80.0
offset_right = 1233.0
offset_bottom = 276.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"The 'Temple' in Sun Temple is a metaphor. The 'Temple' in Moon Temple is a sprawling cathedral built into a mountainside."

[node name="RichTextLabel2" type="RichTextLabel" parent="MoonTemple/CutsceneNode2"]
offset_left = 845.0
offset_top = 299.0
offset_right = 1375.0
offset_bottom = 420.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"That highlights the crux of that difference quite well, doesn't it?"

[node name="RichTextLabel3" type="RichTextLabel" parent="MoonTemple/CutsceneNode2"]
offset_left = 925.0
offset_top = 444.0
offset_right = 1559.0
offset_bottom = 640.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"Holiness is still real to the Elves. In human kingdoms--or at Sun Temple, at least, 'sacred' is a concept that's only ever used metaphorically."

[node name="RichTextLabel4" type="RichTextLabel" parent="MoonTemple/CutsceneNode2"]
offset_left = 834.0
offset_top = 663.0
offset_right = 1468.0
offset_bottom = 784.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"If a human says, 'trust is sacred', they mean trust is a deeply held value of theirs."

[node name="RichTextLabel5" type="RichTextLabel" parent="MoonTemple/CutsceneNode2"]
offset_left = 943.0
offset_top = 805.0
offset_right = 1577.0
offset_bottom = 926.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"But an Elf hears, 'Trust is a sacrament of one or more Gods.\""

[node name="CutsceneNode3" parent="MoonTemple" instance=ExtResource("2_xxf8h")]
visible = false

[node name="bg" type="Sprite2D" parent="MoonTemple/CutsceneNode3"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_ao1sr")
centered = false

[node name="taylor2" type="Sprite2D" parent="MoonTemple/CutsceneNode3"]
position = Vector2(481, 868)
scale = Vector2(0.7, 0.7)
texture = ExtResource("16_4086h")

[node name="RichTextLabel" type="RichTextLabel" parent="MoonTemple/CutsceneNode3"]
offset_left = 840.0
offset_top = 356.0
offset_right = 1349.0
offset_bottom = 510.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"Go ahead and cut me off when I run my mouth. I'm unlikely to ever stop of my own accord.\""

[node name="RichTextLabel2" type="RichTextLabel" parent="MoonTemple/CutsceneNode3"]
offset_left = 723.0
offset_top = 249.0
offset_right = 1136.0
offset_bottom = 334.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"I'm rambling again."

[node name="Salvagers" parent="." instance=ExtResource("16_2qebk")]

[node name="CutsceneNode" parent="Salvagers" instance=ExtResource("2_xxf8h")]
visible = false

[node name="bg" type="Sprite2D" parent="Salvagers/CutsceneNode"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_ao1sr")
centered = false

[node name="taylor2" type="Sprite2D" parent="Salvagers/CutsceneNode"]
position = Vector2(481, 868)
scale = Vector2(0.7, 0.7)
texture = ExtResource("31_kx3if")

[node name="RichTextLabel" type="RichTextLabel" parent="Salvagers/CutsceneNode"]
offset_left = 764.0
offset_top = 148.0
offset_right = 1517.0
offset_bottom = 313.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"Full time salvaging? I can't imagine. Adventures like this are best left to people like Brona. I can't wait to get back to my office at the hospital.\""

[node name="Medics" parent="." instance=ExtResource("17_j8no1")]

[node name="CutsceneNode" parent="Medics" instance=ExtResource("2_xxf8h")]
visible = false

[node name="bg" type="Sprite2D" parent="Medics/CutsceneNode"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_ao1sr")
centered = false

[node name="taylor2" type="Sprite2D" parent="Medics/CutsceneNode"]
position = Vector2(481, 868)
scale = Vector2(0.7, 0.7)
texture = ExtResource("31_kx3if")

[node name="RichTextLabel" type="RichTextLabel" parent="Medics/CutsceneNode"]
offset_left = 764.0
offset_top = 128.0
offset_right = 1242.0
offset_bottom = 280.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"We can be a bitter lot, but we do mean well, most of the time.\""

[node name="RichTextLabel2" type="RichTextLabel" parent="Medics/CutsceneNode"]
offset_left = 866.0
offset_top = 306.0
offset_right = 1344.0
offset_bottom = 508.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"It's just that there's always so much [i]work[/i] to be done, and we can't afford to mess up on [i]any[/i] of it.\""

[node name="RichTextLabel3" type="RichTextLabel" parent="Medics/CutsceneNode"]
offset_left = 960.0
offset_top = 536.0
offset_right = 1438.0
offset_bottom = 660.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"That aside--I do like the job well enough, I suppose.\""

[node name="Engineers" parent="." instance=ExtResource("18_mve8y")]

[node name="Eng" parent="Engineers" node_paths=PackedStringArray("next") instance=ExtResource("2_xxf8h")]
visible = false
next = NodePath("../Eng2")

[node name="bg" type="Sprite2D" parent="Engineers/Eng"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_ao1sr")
centered = false

[node name="taylor2" type="Sprite2D" parent="Engineers/Eng"]
position = Vector2(481, 868)
scale = Vector2(0.7, 0.7)
texture = ExtResource("31_kx3if")

[node name="RichTextLabel" type="RichTextLabel" parent="Engineers/Eng"]
offset_left = 776.0
offset_top = 215.0
offset_right = 1313.0
offset_bottom = 335.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"I took an interest as a kid, of course but, ah--"

[node name="RichTextLabel2" type="RichTextLabel" parent="Engineers/Eng"]
offset_left = 888.0
offset_top = 363.0
offset_right = 1425.0
offset_bottom = 483.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"I'm a Half-Elf. I can mess up electronics just by touching them."

[node name="Eng2" parent="Engineers" instance=ExtResource("2_xxf8h")]
visible = false

[node name="bg" type="Sprite2D" parent="Engineers/Eng2"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_ao1sr")
centered = false

[node name="taylor2" type="Sprite2D" parent="Engineers/Eng2"]
position = Vector2(481, 868)
scale = Vector2(0.7, 0.7)
texture = ExtResource("31_kx3if")

[node name="RichTextLabel" type="RichTextLabel" parent="Engineers/Eng2"]
offset_left = 814.0
offset_top = 111.0
offset_right = 1351.0
offset_bottom = 355.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"Come to think of it, that weird ... knack of yours interfering in your [i]favour[/i] is probably the only reason you're not in the same boat, isn't it?"

[node name="RichTextLabel2" type="RichTextLabel" parent="Engineers/Eng2"]
offset_left = 992.0
offset_top = 377.0
offset_right = 1421.0
offset_bottom = 501.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"I don't know that I'd ever considered that before ...\""

[node name="Taylor" parent="." instance=ExtResource("21_dgpl7")]

[node name="CutsceneNode" parent="Taylor" instance=ExtResource("2_xxf8h")]
visible = false

[node name="bg" type="Sprite2D" parent="Taylor/CutsceneNode"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_ao1sr")
centered = false

[node name="taylor2" type="Sprite2D" parent="Taylor/CutsceneNode"]
position = Vector2(481, 868)
scale = Vector2(0.7, 0.7)
texture = ExtResource("31_kx3if")

[node name="RichTextLabel2" type="RichTextLabel" parent="Taylor/CutsceneNode"]
offset_left = -1.0
offset_top = 875.0
offset_right = 1979.0
offset_bottom = 995.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"Oh. I'm all right. Thanks for asking.\""

[node name="Nate" parent="." instance=ExtResource("22_bs0i6")]

[node name="Nate" parent="Nate" node_paths=PackedStringArray("next") instance=ExtResource("2_xxf8h")]
visible = false
next = NodePath("../Nate2")

[node name="bg" type="Sprite2D" parent="Nate/Nate"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_ao1sr")
centered = false

[node name="taylor2" type="Sprite2D" parent="Nate/Nate"]
position = Vector2(481, 868)
scale = Vector2(0.7, 0.7)
texture = ExtResource("31_kx3if")

[node name="RichTextLabel" type="RichTextLabel" parent="Nate/Nate"]
offset_left = 748.0
offset_top = 136.0
offset_right = 1392.0
offset_bottom = 345.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"I don't see why everyone's always mad at him. He doesn't [i]pick[/i] fights--he just doesn't ignore insult the same as everybody else does."

[node name="Nate2" parent="Nate" instance=ExtResource("2_xxf8h")]
visible = false

[node name="bg" type="Sprite2D" parent="Nate/Nate2"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_ao1sr")
centered = false

[node name="taylor2" type="Sprite2D" parent="Nate/Nate2"]
position = Vector2(481, 868)
scale = Vector2(0.7, 0.7)
texture = ExtResource("31_kx3if")

[node name="RichTextLabel" type="RichTextLabel" parent="Nate/Nate2"]
offset_left = 750.0
offset_top = 88.0
offset_right = 1394.0
offset_bottom = 321.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"But he doesn't hold a grudge, either. Make Nate mad once? You've made him mad once. He won't hold it against you if you don't hold it against him."

[node name="RichTextLabel2" type="RichTextLabel" parent="Nate/Nate2"]
offset_left = 962.0
offset_top = 346.0
offset_right = 1606.0
offset_bottom = 545.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"Argue it out. He's not made of glass. And when the argument's finished? It's over. No mess. Once you realize that, he's actually pretty easy to talk to.\""

[node name="Jerry" parent="." instance=ExtResource("23_kdbo1")]

[node name="CutsceneNode" parent="Jerry" instance=ExtResource("2_xxf8h")]
visible = false

[node name="bg" type="Sprite2D" parent="Jerry/CutsceneNode"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_ao1sr")
centered = false

[node name="taylor2" type="Sprite2D" parent="Jerry/CutsceneNode"]
position = Vector2(481, 868)
scale = Vector2(0.7, 0.7)
texture = ExtResource("31_kx3if")

[node name="RichTextLabel" type="RichTextLabel" parent="Jerry/CutsceneNode"]
offset_left = 754.0
offset_top = 215.0
offset_right = 1228.0
offset_bottom = 385.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"Jerry's good. Sanest Salvager I ever met. I have nothing but respect for that man.\""

[node name="EndOfTheWorld" parent="." instance=ExtResource("24_4l1fl")]

[node name="CutsceneNode" parent="EndOfTheWorld" instance=ExtResource("2_xxf8h")]
visible = false

[node name="bg" type="Sprite2D" parent="EndOfTheWorld/CutsceneNode"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_ao1sr")
centered = false

[node name="taylor2" type="Sprite2D" parent="EndOfTheWorld/CutsceneNode"]
position = Vector2(481, 868)
scale = Vector2(0.7, 0.7)
texture = ExtResource("31_kx3if")

[node name="RichTextLabel" type="RichTextLabel" parent="EndOfTheWorld/CutsceneNode"]
offset_left = -1.0
offset_top = 833.0
offset_right = 1979.0
offset_bottom = 995.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"The Age of Sun is ended, certainly. But the world? How can that be? We're all here, aren't we?
There's still life; still people; still Leylines. No. Things are changing. Can't tell you which way
they're headed, but I'm confident this isn't the [i]end[/i].\""

[node name="Plague of Dreams" parent="." instance=ExtResource("25_bpwdp")]

[node name="Plague" parent="Plague of Dreams" node_paths=PackedStringArray("next") instance=ExtResource("2_xxf8h")]
visible = false
next = NodePath("../Plague2")

[node name="bg" type="Sprite2D" parent="Plague of Dreams/Plague"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_ao1sr")
centered = false

[node name="taylor2" type="Sprite2D" parent="Plague of Dreams/Plague"]
position = Vector2(481, 868)
scale = Vector2(0.7, 0.7)
texture = ExtResource("31_kx3if")

[node name="RichTextLabel" type="RichTextLabel" parent="Plague of Dreams/Plague"]
offset_left = 743.0
offset_top = 69.0
offset_right = 1195.0
offset_bottom = 345.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"Back at Moon Temple, there were people who dreamed the Demon's dreams, slowly losing their bodies to the Leyline's damage. "

[node name="RichTextLabel2" type="RichTextLabel" parent="Plague of Dreams/Plague"]
offset_left = 833.0
offset_top = 381.0
offset_right = 1285.0
offset_bottom = 657.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"Young men who walked with canes, or didn't walk at all, sleeping more, and more, knowing one day soon, they wouldn't rise again."

[node name="RichTextLabel3" type="RichTextLabel" parent="Plague of Dreams/Plague"]
offset_left = 975.0
offset_top = 695.0
offset_right = 1385.0
offset_bottom = 927.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"They told me you could go on for years that way, getting worse, and
weaker, and stranger in the head, but not dying.\""

[node name="Plague2" parent="Plague of Dreams" node_paths=PackedStringArray("next") instance=ExtResource("2_xxf8h")]
visible = false
next = NodePath("../Plague5")

[node name="bg" type="Sprite2D" parent="Plague of Dreams/Plague2"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_ao1sr")
centered = false

[node name="taylor2" type="Sprite2D" parent="Plague of Dreams/Plague2"]
position = Vector2(481, 868)
scale = Vector2(0.7, 0.7)
texture = ExtResource("31_kx3if")

[node name="RichTextLabel" type="RichTextLabel" parent="Plague of Dreams/Plague2"]
offset_left = 743.0
offset_top = 205.0
offset_right = 1385.0
offset_bottom = 359.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"Elves can, was what I learned, when I studied human medicine. Humans certainly cannot."

[node name="RichTextLabel2" type="RichTextLabel" parent="Plague of Dreams/Plague2"]
offset_left = 787.0
offset_top = 389.0
offset_right = 1429.0
offset_bottom = 509.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"I've treated several now. None have lived past a few months.\""

[node name="Plague5" parent="Plague of Dreams" node_paths=PackedStringArray("next") instance=ExtResource("2_xxf8h")]
visible = false
next = NodePath("../Plague3")

[node name="bg" type="Sprite2D" parent="Plague of Dreams/Plague5"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_ao1sr")
centered = false

[node name="taylor2" type="Sprite2D" parent="Plague of Dreams/Plague5"]
position = Vector2(481, 868)
scale = Vector2(0.7, 0.7)
texture = ExtResource("31_kx3if")

[node name="RichTextLabel" type="RichTextLabel" parent="Plague of Dreams/Plague5"]
offset_left = 743.0
offset_top = 205.0
offset_right = 1385.0
offset_bottom = 393.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"If someone like me--a half-Elf, that is--were to contract it, I couldn't say what would happen. There have been too few case studies.\""

[node name="Plague3" parent="Plague of Dreams" node_paths=PackedStringArray("next") instance=ExtResource("2_xxf8h")]
visible = false
next = NodePath("../Plague4")

[node name="bg" type="Sprite2D" parent="Plague of Dreams/Plague3"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_ao1sr")
centered = false

[node name="taylor2" type="Sprite2D" parent="Plague of Dreams/Plague3"]
position = Vector2(481, 868)
scale = Vector2(0.7, 0.7)
texture = ExtResource("31_kx3if")

[node name="RichTextLabel" type="RichTextLabel" parent="Plague of Dreams/Plague3"]
offset_left = 731.0
offset_top = 75.0
offset_right = 1519.0
offset_bottom = 273.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"They say the Plague of Dreams began before the Demons emerged--that at one point, when Man still lived connected to Leylines, the Plague flowed right out of them, and into the souls of those it touched. "

[node name="RichTextLabel3" type="RichTextLabel" parent="Plague of Dreams/Plague3"]
offset_left = 779.0
offset_top = 305.0
offset_right = 1567.0
offset_bottom = 431.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"When Man tried to slay the Leyline to control the spread, goes the theory, it ended the world."

[node name="RichTextLabel2" type="RichTextLabel" parent="Plague of Dreams/Plague3"]
offset_left = 819.0
offset_top = 461.0
offset_right = 1607.0
offset_bottom = 629.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"Well. There are many theories on [i]what[/i] it is we tried to slay. The Plague. The first of the Demons. The Leyline. Magic itself.\""

[node name="Plague4" parent="Plague of Dreams" instance=ExtResource("2_xxf8h")]
visible = false

[node name="bg" type="Sprite2D" parent="Plague of Dreams/Plague4"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_ao1sr")
centered = false

[node name="taylor2" type="Sprite2D" parent="Plague of Dreams/Plague4"]
position = Vector2(481, 868)
scale = Vector2(0.7, 0.7)
texture = ExtResource("31_kx3if")

[node name="RichTextLabel" type="RichTextLabel" parent="Plague of Dreams/Plague4"]
offset_left = 751.0
offset_top = 87.0
offset_right = 1465.0
offset_bottom = 361.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"In any case, the Plague of Dreams, so called, presumably, due to the hypersomnia it induces in its late stage, is mostly contracted through contact with Demons in the modern day--though it's been known to manifest after Leyline electrocution as well, in rare cases. "
metadata/_edit_use_anchors_ = true

[node name="RichTextLabel3" type="RichTextLabel" parent="Plague of Dreams/Plague4"]
offset_left = 805.0
offset_top = 396.0
offset_right = 1427.0
offset_bottom = 590.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"It's incurable, and terminal, with a notably more protracted course--and more psychological symptoms--in Elves than in humans.\""

[node name="RichTextLabel2" type="RichTextLabel" parent="Plague of Dreams/Plague4"]
offset_left = 773.0
offset_top = 628.0
offset_right = 1351.0
offset_bottom = 706.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"I hope that answers your question.\""

[node name="Demons" parent="." instance=ExtResource("26_5kt1y")]

[node name="CutsceneNode" parent="Demons" instance=ExtResource("2_xxf8h")]
visible = false

[node name="bg" type="Sprite2D" parent="Demons/CutsceneNode"]
scale = Vector2(1.35, 1.35)
