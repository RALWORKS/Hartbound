text = "\"I'm [i]Anaem Eon Ril Ceyn Suól.[/i]"

[node name="RichTextLabel4" type="RichTextLabel" parent="ElvenNames/ElvenNamePost"]
offset_left = 838.0
offset_top = 229.0
