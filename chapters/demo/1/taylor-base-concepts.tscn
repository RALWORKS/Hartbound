offset_bottom = 319.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"Ah ... I'm just the medic, remember? The only thing I know about the machines you work with is treating the injuries they cause.\""

