theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"The ingenuity of engineers and salvagers ..."

[node name="RichTextLabel2" type="RichTextLabel" parent="C1CollectingComponents/Components3"]
