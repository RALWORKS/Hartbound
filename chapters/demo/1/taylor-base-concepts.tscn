[node name="RichTextLabel2" type="RichTextLabel" parent="MyHometown/NewMemory"]
offset_left = 386.0
offset_top = 789.0
offset_right = 950.0
offset_bottom = 878.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"I was born in a village in the woods. "

[node name="RichTextLabel3" type="RichTextLabel" parent="MyHometown/NewMemory"]
offset_left = 387.0
offset_top = 896.0
offset_right = 951.0
offset_bottom = 1025.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"Its name was [i]Fin Soen Li Yen[/i]: Grove of the Seven Ferns."

[node name="NewMemory2" parent="MyHometown" node_paths=PackedStringArray("next") instance=ExtResource("2_xxf8h")]
visible = false
next = NodePath("../NewMemory4")

[node name="bg" type="Sprite2D" parent="MyHometown/NewMemory2"]
position = Vector2(-70, -432)
scale = Vector2(1.2, 1.2)
texture = ExtResource("42_gmm22")
centered = false

[node name="taylor2" type="Sprite2D" parent="MyHometown/NewMemory2"]
material = SubResource("ShaderMaterial_weoi2")
position = Vector2(481, 868)
scale = Vector2(0.7, 0.7)
texture = ExtResource("31_kx3if")

[node name="Profile" parent="MyHometown/NewMemory2" instance=ExtResource("41_8awtg")]
material = SubResource("ShaderMaterial_k6to6")
position = Vector2(912, 105)
scale = Vector2(2, 2)
texture = SubResource("ViewportTexture_clk6n")
with_background = false

[node name="RichTextLabel2" type="RichTextLabel" parent="MyHometown/NewMemory2"]
offset_left = 10.0
offset_top = 773.0
offset_right = 864.0
offset_bottom = 893.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"It was almost as different from Moon Temple as Moon Temple is from the human lands."

[node name="RichTextLabel3" type="RichTextLabel" parent="MyHometown/NewMemory2"]
offset_left = 12.0
offset_top = 903.0
offset_right = 1241.0
offset_bottom = 981.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"Not even one church in town. We prayed in the clearing at the centre of the village."

[node name="RichTextLabel4" type="RichTextLabel" parent="MyHometown/NewMemory2"]
offset_left = 12.0
offset_top = 992.0
offset_right = 942.0
offset_bottom = 1070.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"I was Named under the moonlight, as our ancestors were."

[node name="NewMemory4" parent="MyHometown" node_paths=PackedStringArray("next") instance=ExtResource("2_xxf8h")]
visible = false
next = NodePath("../NewMemory3")

[node name="bg" type="Sprite2D" parent="MyHometown/NewMemory4"]
position = Vector2(-70, -432)
scale = Vector2(1.2, 1.2)
texture = ExtResource("42_gmm22")
centered = false

[node name="taylor2" type="Sprite2D" parent="MyHometown/NewMemory4"]
material = SubResource("ShaderMaterial_d26op")
position = Vector2(481, 868)
scale = Vector2(0.7, 0.7)
texture = ExtResource("31_kx3if")

[node name="Profile" parent="MyHometown/NewMemory4" instance=ExtResource("41_8awtg")]
material = SubResource("ShaderMaterial_n2xtb")
position = Vector2(912, 105)
scale = Vector2(2, 2)
texture = SubResource("ViewportTexture_baon2")
with_background = false

[node name="RichTextLabel5" type="RichTextLabel" parent="MyHometown/NewMemory4"]
offset_left = 12.0
offset_top = 727.0
offset_right = 991.0
offset_bottom = 805.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"I chased chickens and drew up water from the well with a bucket."

[node name="RichTextLabel6" type="RichTextLabel" parent="MyHometown/NewMemory4"]
offset_left = 12.0
offset_top = 817.0
offset_right = 1218.0
offset_bottom = 931.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"We grew up pestering the shopkeeper of that single general store in town to show us what the traders brought in, so we could beg our parents for trinkets."

[node name="RichTextLabel7" type="RichTextLabel" parent="MyHometown/NewMemory4"]
offset_left = 12.0
offset_top = 943.0
offset_right = 1050.0
offset_bottom = 1066.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"We ran into [i]bears[/i] more often than we did outsiders. Those forty-odd faces that I saw every day made up the world as I knew it."

