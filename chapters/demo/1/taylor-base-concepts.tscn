[node name="RichTextLabel7" type="RichTextLabel" parent="MyHometown/NewMemory5"]
offset_left = 742.0
offset_top = 184.0
offset_right = 1332.0
offset_bottom = 345.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"You hear those stories more than you used to these days. It's dark times."

[node name="RichTextLabel8" type="RichTextLabel" parent="MyHometown/NewMemory5"]
offset_left = 850.0
offset_top = 357.0
offset_right = 1375.0
offset_bottom = 518.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"But all the same, I don't like hearing one from a friend."

[node name="RichTextLabel9" type="RichTextLabel" parent="MyHometown/NewMemory5"]
offset_left = 967.0
offset_top = 523.0
offset_right = 1492.0
offset_bottom = 684.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"You have my ... solidarity, for what it's worth."

