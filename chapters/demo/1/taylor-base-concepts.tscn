offset_right = 1399.0
offset_bottom = 279.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"My human name is a play on my Elven name's meaning."

[node name="RichTextLabel3" type="RichTextLabel" parent="HumanNames/CutsceneNode"]
offset_left = 780.0
offset_top = 308.0
offset_right = 1531.0
offset_bottom = 388.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"Yours has got to be from the sound, right?"

[node name="RichTextLabel5" type="RichTextLabel" parent="HumanNames/CutsceneNode"]
offset_left = 825.0
offset_top = 550.0
offset_right = 1576.0
offset_bottom = 685.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"I love how they can't just [i]learn to pronounce a name.[/i] It's not like either of our names is hard."

[node name="SmartLabel" parent="HumanNames/CutsceneNode" instance=ExtResource("35_4myvh")]
