theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"You've been calling me Ceyntya, so I'm guessing you haven't forgotten.\""

[node name="RichTextLabel5" type="RichTextLabel" parent="ElvenNames/ElvenNamePost"]
