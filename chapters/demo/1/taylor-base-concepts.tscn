texture = ExtResource("31_kx3if")

[node name="RichTextLabel" type="RichTextLabel" parent="Leylines/Leyline"]
offset_left = 759.0
offset_top = 64.0
offset_right = 1263.0
offset_bottom = 297.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"Herbs grow better on the Leylines. Elves say Magic runs stronger there, and plants seem to interface with Magic, so I imagine that's why. "

[node name="RichTextLabel2" type="RichTextLabel" parent="Leylines/Leyline"]
offset_left = 759.0
offset_top = 321.0
offset_right = 1379.0
offset_bottom = 612.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"The Elves carry their wounded to the Leyline after a battle. It's said to speed healing. I haven't been able to verify it [i]does[/i], but I keep it in my back pocket as something to try, if I run into a situation desperate enough to warrant it.\""

[node name="C1CollectingHerbs" parent="." instance=ExtResource("29_0ktl4")]

[node name="Herbs" parent="C1CollectingHerbs" instance=ExtResource("2_xxf8h")]
visible = false

[node name="bg" type="Sprite2D" parent="C1CollectingHerbs/Herbs"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_ao1sr")
centered = false

[node name="taylor2" type="Sprite2D" parent="C1CollectingHerbs/Herbs"]
position = Vector2(455, 850)
scale = Vector2(0.7, 0.7)
texture = ExtResource("31_kx3if")

[node name="RichTextLabel" type="RichTextLabel" parent="C1CollectingHerbs/Herbs"]
offset_left = 759.0
offset_top = 64.0
offset_right = 1263.0
offset_bottom = 297.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"Oh, don't worry about that. I'll stop you if I see a good patch, and then we can grab them and move on. I'll hardly even slow you down.\""

[node name="C1CollectingComponents" parent="." instance=ExtResource("30_hcq24")]

[node name="Components" parent="C1CollectingComponents" node_paths=PackedStringArray("next") instance=ExtResource("2_xxf8h")]
