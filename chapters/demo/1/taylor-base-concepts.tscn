[node name="RichTextLabel" type="RichTextLabel" parent="Generators/CutsceneNode"]
offset_left = -1.0
offset_top = 875.0
offset_right = 1979.0
offset_bottom = 995.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"Being a medic, I don't know all that much about them.\""

[node name="Leylines" parent="." instance=ExtResource("29_802h3")]

[node name="Leyline" parent="Leylines" instance=ExtResource("2_xxf8h")]
visible = false

[node name="bg" type="Sprite2D" parent="Leylines/Leyline"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_ao1sr")
