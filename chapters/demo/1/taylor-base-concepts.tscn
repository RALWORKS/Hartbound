centered = false

[node name="taylor2" type="Sprite2D" parent="Demons/CutsceneNode"]
position = Vector2(455, 850)
scale = Vector2(0.7, 0.7)
texture = ExtResource("31_kx3if")

[node name="RichTextLabel" type="RichTextLabel" parent="Demons/CutsceneNode"]
offset_left = -1.0
offset_top = 875.0
offset_right = 1979.0
offset_bottom = 995.0
theme = ExtResource("5_yjk2e")
theme_type_variation = &"VoiceoverBox"
text = "\"The Sentinels of the Leyline, the Elves teach. Perhaps. But they say the Leyline was once Man's
creation. Who is to say it's not Man's right to try and reclaim it.\""

[node name="GeneratorCrews" parent="." instance=ExtResource("27_v2sg7")]

[node name="CutsceneRedirectNode" parent="GeneratorCrews" node_paths=PackedStringArray("next") instance=ExtResource("8_nd0ea")]
visible = false
next = NodePath("../../Salvagers/CutsceneNode")

[node name="Generators" parent="." instance=ExtResource("28_8lo38")]

