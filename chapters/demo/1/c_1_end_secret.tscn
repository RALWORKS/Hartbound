[node name="taylor" parent="NoHalfBelieves" index="1" instance=ExtResource("4_rdl5b")]
position = Vector2(1205, 1696)
scale = Vector2(1.5, 1.5)

[node name="Profile" parent="NoHalfBelieves" index="2" instance=ExtResource("9_74vd7")]
position = Vector2(-200, 73)
