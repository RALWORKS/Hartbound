[node name="SmartLabel" parent="YesHalfBelieves" index="3" instance=ExtResource("5_f4mtt")]
offset_top = 829.0
offset_right = 1939.0
offset_bottom = 949.0
text = "\"I've drifted a little from the ways I was raised with, but I still hold to them well enough to feel like a stranger
in Sun Temple sometimes, even now. I don't blame you for wanting to get away from that.\""

