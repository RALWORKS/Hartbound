[node name="SmartLabel" parent="NoFullyBelieves" index="3" instance=ExtResource("5_f4mtt")]
offset_top = 829.0
offset_right = 1939.0
offset_bottom = 981.0
text = "\"I'm like you. I've been praying for the Saint of Dusk all this time. I've been pining after my home.
But the place I was born isn't there anymore. I don't have anywhere to go but Sun Temple now.
I can't risk losing this place because I helped you defect.\""

[node name="NoHalfBelieves" parent="." index="13" node_paths=PackedStringArray("next") instance=ExtResource("2_teree")]
visible = false
next = NodePath("../NoSegue")

[node name="bg" type="Sprite2D" parent="NoHalfBelieves" index="0"]
