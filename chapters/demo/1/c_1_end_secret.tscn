[node name="SmartLabel" parent="NoDisBelieves" index="3" instance=ExtResource("5_f4mtt")]
offset_top = 829.0
offset_right = 1939.0
offset_bottom = 999.0
bbcode_enabled = true
text = "\"I [i]don't[/i] pray for the Saint of Dusk. I don't pray to the Elven Gods at all, but if I did, I would pray for [i]Sunrise[/i].
I don't want Moon Temple to win this war, <taylor>, and while I don't want to see you hurt for trying to run,
[i]I draw the line at helping you help them.[/i]\""

