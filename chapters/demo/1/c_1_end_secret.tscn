flip_h = true
with_background = false
start_frown = true

[node name="SmartLabel" parent="NoHalfBelieves" index="3" instance=ExtResource("5_f4mtt")]
offset_top = 829.0
offset_right = 1939.0
offset_bottom = 977.0
text = "\"I'm still an Elf. I'm still hanging onto the culture that I grew up with, to the exent that I can--but I've learned
a lot from the people at Sun Temple. I don't want to risk losing my place here by getting caught up in your
escape plan.\""

