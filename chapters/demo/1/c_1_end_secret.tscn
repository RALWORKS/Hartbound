[node name="SmartLabel" parent="YesFullyBelieves" index="3" instance=ExtResource("5_f4mtt")]
offset_top = 829.0
offset_right = 1939.0
offset_bottom = 949.0
text = "\"I know what's it's like to live at Sun Temple and pray for the Moonrise. I won't be leaving with you,
but I'll help you get out.\""

