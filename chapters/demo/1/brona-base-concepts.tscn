centered = false

[node name="brona" type="Sprite2D" parent="Jerry/jerry"]
position = Vector2(455, 850)
scale = Vector2(0.7, 0.7)
texture = ExtResource("4_m03cx")

[node name="RichTextLabel" type="RichTextLabel" parent="Jerry/jerry"]
offset_left = 754.0
offset_top = 215.0
offset_right = 1204.0
offset_bottom = 335.0
theme = ExtResource("5_dpfjf")
theme_type_variation = &"VoiceoverBox"
text = "\"Jerry's the best. He's been like a second father to me.\""

[node name="RichTextLabel2" type="RichTextLabel" parent="Jerry/jerry"]
offset_left = 847.0
offset_top = 371.0
offset_right = 1297.0
offset_bottom = 554.0
theme = ExtResource("5_dpfjf")
theme_type_variation = &"VoiceoverBox"
text = "\"He might seem harsh at times, but if you keep the bullshit to a minimum, he's a really nice guy.\""

[node name="jerry2" parent="Jerry" instance=ExtResource("2_1oki1")]
visible = false

[node name="bg" type="Sprite2D" parent="Jerry/jerry2"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_4jg2d")
centered = false

[node name="brona" type="Sprite2D" parent="Jerry/jerry2"]
position = Vector2(455, 850)
scale = Vector2(0.7, 0.7)
texture = ExtResource("4_m03cx")

[node name="RichTextLabel" type="RichTextLabel" parent="Jerry/jerry2"]
offset_left = 754.0
offset_top = 215.0
offset_right = 1204.0
offset_bottom = 371.0
theme = ExtResource("5_dpfjf")
theme_type_variation = &"VoiceoverBox"
text = "\"Of course, Jerry's idea of bullshit and my idea of fun ..."

[node name="RichTextLabel2" type="RichTextLabel" parent="Jerry/jerry2"]
offset_left = 847.0
offset_top = 404.0
offset_right = 1324.0
offset_bottom = 605.0
theme = ExtResource("5_dpfjf")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"... can tend to overlap a little. But he knows I know better than to do anything [i]really[/i] stupid. We trust each other.\""

[node name="EndOfTheWorld" parent="." instance=ExtResource("24_ri8dn")]

[node name="CutsceneNode" parent="EndOfTheWorld" instance=ExtResource("2_1oki1")]
