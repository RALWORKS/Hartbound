[node name="RichTextLabel" type="RichTextLabel" parent="Leylines/CutsceneNode"]
offset_left = -1.0
offset_top = 832.0
offset_right = 1979.0
offset_bottom = 995.0
theme = ExtResource("5_dpfjf")
theme_type_variation = &"VoiceoverBox"
text = "\"Medics love 'em, engineers hate 'em, I don't give a damn because most of the stuff
I go after isn't affected by them either way. Though they do tend to have Demons
hanging around 'em, so there's always that to be aware of.\""

[node name="PlanForAfternoon" parent="." instance=ExtResource("30_c2xcg")]

[node name="CutsceneNode" parent="PlanForAfternoon" instance=ExtResource("2_1oki1")]
