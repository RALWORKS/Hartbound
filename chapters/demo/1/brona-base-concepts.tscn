[node name="RichTextLabel" type="RichTextLabel" parent="HowAreYou/Brona1"]
offset_left = -1.0
offset_top = 875.0
offset_right = 1944.0
offset_bottom = 995.0
theme = ExtResource("5_dpfjf")
theme_type_variation = &"VoiceoverBox"
text = "\"Oh, I'm doing all right. I'd been on back to back expeditions since May, but I finally managed to get some time off last
month. So I'm rested and ready to go!\""

[node name="WhatDoYouThinkOfMe" parent="." instance=ExtResource("35_tnwyp")]

