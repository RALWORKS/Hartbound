[node name="RichTextLabel" type="RichTextLabel" parent="Salvagers/CutsceneNode"]
offset_left = 684.0
offset_top = 218.0
offset_right = 1437.0
offset_bottom = 411.0
theme = ExtResource("5_dpfjf")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"Oh, it's the [i]best[/i] job. Never cooped up in a room--always exploring--always learning. I feel so sorry for you Medics and Engineers who only get to come out with us every few months.\""

