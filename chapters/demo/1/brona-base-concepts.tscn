offset_right = 1979.0
offset_bottom = 995.0
theme = ExtResource("5_dpfjf")
theme_type_variation = &"VoiceoverBox"
text = "\"Growing up, I had a neighbour who was dying of it. Young guy. A salvager. Bet Jerry knew him.\""

[node name="plague2" parent="Plague of Dreams" instance=ExtResource("2_1oki1")]
