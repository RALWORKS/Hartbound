[node name="RichTextLabel" type="RichTextLabel" parent="MoonTemple/CutsceneNode"]
offset_left = -1.0
offset_top = 832.0
offset_right = 1979.0
offset_bottom = 995.0
theme = ExtResource("5_dpfjf")
theme_type_variation = &"VoiceoverBox"
text = "\"The big Elven city? I don't really know much about it.  They're supposed to be our enemy, I guess.
But the only people I've ever know with any Moon Temple ties would be you--or your parents ,
anyway--and Taylor. And you guys both seem all right.\""

[node name="Salvagers" parent="." instance=ExtResource("16_qnywx")]

