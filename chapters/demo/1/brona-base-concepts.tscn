text = "\"The Altars of Sun Temple. Keeping them running--keeping the City and the Age alive--
that's what drives us all.\""

[node name="Leylines" parent="." instance=ExtResource("29_xgcf1")]

[node name="CutsceneNode" parent="Leylines" instance=ExtResource("2_1oki1")]
