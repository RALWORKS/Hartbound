offset_bottom = 995.0
theme = ExtResource("5_dpfjf")
theme_type_variation = &"VoiceoverBox"
text = "\"...Oh!
Sorry. I didn't mean to ... insult your religion, or whatever. I just ... wasn't raised that way, you know?\""

[node name="AOD4" parent="Age of Dusk" instance=ExtResource("2_1oki1")]
visible = false

[node name="bg" type="Sprite2D" parent="Age of Dusk/AOD4"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_4jg2d")
centered = false
script = ExtResource("5_lh1bw")

[node name="brona" type="Sprite2D" parent="Age of Dusk/AOD4"]
position = Vector2(455, 850)
scale = Vector2(0.7, 0.7)
texture = ExtResource("4_m03cx")

[node name="RichTextLabel" type="RichTextLabel" parent="Age of Dusk/AOD4"]
offset_left = -1.0
offset_top = 875.0
offset_right = 1944.0
offset_bottom = 995.0
theme = ExtResource("5_dpfjf")
theme_type_variation = &"VoiceoverBox"
text = "\"Yeah, that's kind of the impression I always got.
Me? I'm human, obviously, so I was raised to believe we could bring our era back.\""

