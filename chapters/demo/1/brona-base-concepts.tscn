[node name="RichTextLabel" type="RichTextLabel" parent="Elves/CutsceneNode"]
offset_left = 684.0
offset_top = 198.0
offset_right = 1337.0
offset_bottom = 393.0
theme = ExtResource("5_dpfjf")
theme_type_variation = &"VoiceoverBox"
text = "\"If you're any indication, Elves seem pretty chill.\" She stops to think for a moment. \"Well, Taylor has no chill at all, but she's only half. Maybe it's a Half-Elf problem.\""

[node name="Humans" parent="." instance=ExtResource("13_ajokx")]

[node name="humans1" parent="Humans" instance=ExtResource("2_1oki1")]
visible = false
is_option_node = true

[node name="bg" type="Sprite2D" parent="Humans/humans1"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_4jg2d")
centered = false
script = ExtResource("5_lh1bw")

[node name="brona" type="Sprite2D" parent="Humans/humans1"]
position = Vector2(455, 850)
