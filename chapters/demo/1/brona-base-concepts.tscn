[node name="RichTextLabel" type="RichTextLabel" parent="PlanForAfternoon/CutsceneNode"]
offset_left = -1.0
offset_top = 808.0
offset_right = 1979.0
offset_bottom = 1016.0
theme = ExtResource("5_dpfjf")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"Jerry and me saw this [i]big[/i] sheet of undamaged glass out where we were scouting before,\"
she says.
\"I was hoping we'd be able to go back, and see if we can get it out intact. Might rope Nate in,
[i]if it's not too much trouble for him[/i], since he [i]is[/i] surprisingly good with careful work like that.\""

