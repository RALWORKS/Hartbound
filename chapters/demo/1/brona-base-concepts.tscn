[node name="Elves" parent="." instance=ExtResource("12_3w1ts")]

[node name="CutsceneNode" parent="Elves" instance=ExtResource("2_1oki1")]
visible = false

[node name="bg" type="Sprite2D" parent="Elves/CutsceneNode"]
scale = Vector2(1.35, 1.35)
