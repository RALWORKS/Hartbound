[node name="RichTextLabel" type="RichTextLabel" parent="TellMeAboutYourself/CutsceneNode"]
offset_left = 675.0
offset_top = 101.0
offset_right = 1001.0
offset_bottom = 264.0
theme = ExtResource("5_dpfjf")
theme_type_variation = &"VoiceoverBox"
text = "\"Let's see ... my favourite food is fried eggs."

[node name="RichTextLabel2" type="RichTextLabel" parent="TellMeAboutYourself/CutsceneNode"]
offset_left = 787.0
offset_top = 285.0
offset_right = 1289.0
offset_bottom = 403.0
theme = ExtResource("5_dpfjf")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"I wanted to be a Salvager ever since I was a kid."

[node name="RichTextLabel3" type="RichTextLabel" parent="TellMeAboutYourself/CutsceneNode"]
offset_left = 758.0
offset_top = 427.0
offset_right = 1331.0
offset_bottom = 600.0
theme = ExtResource("5_dpfjf")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"Well, when I was a [i]little[/i] kid I wanted to be a dump truck. [i]Later[/i] I wanted to be a Salvager."

[node name="RichTextLabel4" type="RichTextLabel" parent="TellMeAboutYourself/CutsceneNode"]
offset_left = 841.0
offset_top = 621.0
offset_right = 1414.0
offset_bottom = 780.0
theme = ExtResource("5_dpfjf")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"If I ever get a job that lets me be home every day, I'll get myself a pet rabbit.\""
