to = NodePath("../../humans3")

[node name="humans2" parent="Humans" instance=ExtResource("2_1oki1")]
visible = false

[node name="bg" type="Sprite2D" parent="Humans/humans2"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_4jg2d")
centered = false
script = ExtResource("5_lh1bw")

[node name="brona" type="Sprite2D" parent="Humans/humans2"]
position = Vector2(455, 850)
scale = Vector2(0.7, 0.7)
texture = ExtResource("4_m03cx")

[node name="RichTextLabel" type="RichTextLabel" parent="Humans/humans2"]
offset_left = 680.0
offset_top = 98.0
offset_right = 1274.0
offset_bottom = 218.0
theme = ExtResource("5_dpfjf")
theme_type_variation = &"VoiceoverBox"
text = "\"Right?\" she says. \"Some humans get weird. But we're mostly just scared.\""

[node name="RichTextLabel2" type="RichTextLabel" parent="Humans/humans2"]
offset_left = 762.0
offset_top = 235.0
offset_right = 1356.0
offset_bottom = 468.0
theme = ExtResource("5_dpfjf")
theme_type_variation = &"VoiceoverBox"
text = " \"Elves--I don't really mean you--we grew up with you, but like, Moon Temple elves--they talk about how our era's ended, and theirs is beginning, and to us, it sounds like a threat.\""

[node name="RichTextLabel3" type="RichTextLabel" parent="Humans/humans2"]
offset_left = 847.0
offset_top = 485.0
offset_right = 1441.0
offset_bottom = 678.0
theme = ExtResource("5_dpfjf")
theme_type_variation = &"VoiceoverBox"
text = " \"Not that we're justifed when we take it out on you folks, obviously. Just, if you wanna understand, that's how you gotta look at it.\""

[node name="humans3" parent="Humans" instance=ExtResource("2_1oki1")]
visible = false
end = true

[node name="bg" type="Sprite2D" parent="Humans/humans3"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_4jg2d")
centered = false
script = ExtResource("5_lh1bw")

[node name="brona" type="Sprite2D" parent="Humans/humans3"]
position = Vector2(455, 850)
scale = Vector2(0.7, 0.7)
texture = ExtResource("14_nalcp")

[node name="RichTextLabel" type="RichTextLabel" parent="Humans/humans3"]
offset_left = 565.0
offset_top = 190.0
offset_right = 1033.0
offset_bottom = 360.0
theme = ExtResource("5_dpfjf")
theme_type_variation = &"VoiceoverBox"
text = "\"Well if you're just gonna be racist, then I don't want to talk.\""

[node name="MoonTemple" parent="." instance=ExtResource("15_8sr2o")]

[node name="CutsceneNode" parent="MoonTemple" instance=ExtResource("2_1oki1")]
