theme = ExtResource("5_dpfjf")
theme_type_variation = &"VoiceoverBox"
text = "\"You? You're cool.
Chillest Elf I know!\""

[node name="TellMeAboutYourself" parent="." instance=ExtResource("36_03dnw")]

[node name="CutsceneNode" parent="TellMeAboutYourself" instance=ExtResource("2_1oki1")]

