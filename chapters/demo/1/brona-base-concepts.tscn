offset_right = 1979.0
offset_bottom = 995.0
theme = ExtResource("5_dpfjf")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"The way he was past a month or two? Lord, if a Demon ever gets me, I hope I die on the spot.
I hear elves fare a little better than we do. But then I hear elves ... see things when they get it.
So maybe it [i]isn't[/i] better.\""

