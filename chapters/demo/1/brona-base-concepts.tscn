[node name="RichTextLabel" type="RichTextLabel" parent="Humans/humans1"]
offset_left = 762.0
offset_top = 234.0
offset_right = 1356.0
offset_bottom = 354.0
theme = ExtResource("5_dpfjf")
theme_type_variation = &"VoiceoverBox"
text = "\"I'd say we're a decent enough bunch, generally, wouldn't you?\""

[node name="Yes" parent="Humans/humans1" node_paths=PackedStringArray("to") instance=ExtResource("6_dpdg8")]
offset_left = 762.0
offset_top = 371.0
offset_right = 970.0
