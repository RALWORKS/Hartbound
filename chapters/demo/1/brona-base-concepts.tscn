offset_right = 1979.0
offset_bottom = 995.0
theme = ExtResource("5_dpfjf")
theme_type_variation = &"VoiceoverBox"
text = "\"Jerry says the world isn't ending. But just look around. There obviously used to be ... more.\""

[node name="Plague of Dreams" parent="." instance=ExtResource("25_cn1g3")]

