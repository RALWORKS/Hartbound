theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"Nate's an ass,\" she says."

[node name="nate3" parent="Nate" instance=ExtResource("2_1oki1")]
visible = false

[node name="bg" type="Sprite2D" parent="Nate/nate3"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_4jg2d")
centered = false
script = ExtResource("5_lh1bw")

[node name="brona" type="Sprite2D" parent="Nate/nate3"]
position = Vector2(500, 875)
scale = Vector2(0.7, 0.7)
texture = ExtResource("14_nalcp")

[node name="RichTextLabel" type="RichTextLabel" parent="Nate/nate3"]
offset_left = 684.0
offset_top = 739.0
offset_right = 1441.0
offset_bottom = 1016.0
theme = ExtResource("5_dpfjf")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"You know, the other day, he was fixing that flaky radio again, and I asked whether he was about done, because it was getting dark and we needed to find a camp. Not even, 'hurry up', just, 'are you close?' I swear to God, the dude was ready to throw hands 'til Jerry talked him down.\""

[node name="Jerry" parent="." instance=ExtResource("23_we4km")]

[node name="jerry" parent="Jerry" node_paths=PackedStringArray("next") instance=ExtResource("2_1oki1")]
visible = false
next = NodePath("../jerry2")

[node name="bg" type="Sprite2D" parent="Jerry/jerry"]
scale = Vector2(1.35, 1.35)
