offset_bottom = 221.0
theme = ExtResource("7_8lfnq")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"What's to know?\""

[node name="RichTextLabel2" type="RichTextLabel" parent="TellMeAboutYourself/You"]
offset_left = 904.0
offset_top = 241.0
offset_right = 1132.0
offset_bottom = 326.0
theme = ExtResource("7_8lfnq")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"I'm serious."

[node name="RichTextLabel3" type="RichTextLabel" parent="TellMeAboutYourself/You"]
offset_left = 960.0
offset_top = 345.0
offset_right = 1482.0
offset_bottom = 472.0
theme = ExtResource("7_8lfnq")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"'Hi, I'm Nate and I'm the crew Engineer, good to meet you?'"

[node name="RichTextLabel4" type="RichTextLabel" parent="TellMeAboutYourself/You"]
offset_left = 847.0
offset_top = 492.0
offset_right = 1411.0
offset_bottom = 619.0
theme = ExtResource("7_8lfnq")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"You've known me since we were apprentices. There's nothing to tell.\""
