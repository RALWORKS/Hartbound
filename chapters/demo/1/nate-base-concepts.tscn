theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"[i]Fin Soen Li Yen[/i]?"

[node name="RichTextLabel3" type="RichTextLabel" parent="MyHometown/Default"]
offset_left = 828.0
offset_top = 278.0
offset_right = 1268.0
offset_bottom = 402.0
theme = ExtResource("7_8lfnq")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"Sounds like an Elven town name."

[node name="RichTextLabel4" type="RichTextLabel" parent="MyHometown/Default"]
offset_left = 907.0
offset_top = 422.0
offset_right = 1347.0
offset_bottom = 546.0
theme = ExtResource("7_8lfnq")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"Maybe Taylor knows about it.\""

[node name="TellMeAboutYourself" parent="." instance=ExtResource("25_6v4nu")]

