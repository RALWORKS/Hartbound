[node name="RichTextLabel2" type="RichTextLabel" parent="Generators/gen1"]
offset_left = 834.0
offset_top = 335.0
offset_right = 1354.0
offset_bottom = 463.0
theme = ExtResource("7_8lfnq")
theme_type_variation = &"VoiceoverBox"
text = "\"We could build another plant if we could round up the resources. "

[node name="RichTextLabel3" type="RichTextLabel" parent="Generators/gen1"]
offset_left = 930.0
offset_top = 488.0
offset_right = 1450.0
offset_bottom = 729.0
theme = ExtResource("7_8lfnq")
theme_type_variation = &"VoiceoverBox"
text = "\"And if we could figure out how to repell the Demons for good, and stop the Leyline creeping into the network, we could extend the power grid."

[node name="RichTextLabel4" type="RichTextLabel" parent="Generators/gen1"]
offset_left = 930.0
offset_top = 750.0
offset_right = 1450.0
offset_bottom = 917.0
theme = ExtResource("7_8lfnq")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"Maybe to [i]everywhere[/i] eventually, like it was in the old days.\""

[node name="Leylines" parent="." instance=ExtResource("30_2bjag")]

[node name="Leyline" parent="Leylines" instance=ExtResource("3_jda3c")]
visible = false

[node name="bg" type="Sprite2D" parent="Leylines/Leyline"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("4_hpqxi")
centered = false
script = ExtResource("5_owbps")

[node name="nate" type="Sprite2D" parent="Leylines/Leyline"]
position = Vector2(455, 850)
scale = Vector2(0.7, 0.7)
texture = ExtResource("6_wqi28")

[node name="RichTextLabel" type="RichTextLabel" parent="Leylines/Leyline"]
offset_left = 714.0
offset_top = 81.0
offset_right = 1294.0
offset_bottom = 243.0
theme = ExtResource("7_8lfnq")
theme_type_variation = &"VoiceoverBox"
text = "\"Ah, yes. The greatest impediment to technological progress--worse even than Demons."

[node name="RichTextLabel2" type="RichTextLabel" parent="Leylines/Leyline"]
offset_left = 796.0
offset_top = 273.0
offset_right = 1376.0
offset_bottom = 393.0
theme = ExtResource("7_8lfnq")
theme_type_variation = &"VoiceoverBox"
text = "\"The Leylines ate the power grid of the old world."

[node name="RichTextLabel3" type="RichTextLabel" parent="Leylines/Leyline"]
offset_left = 858.0
offset_top = 423.0
offset_right = 1588.0
offset_bottom = 546.0
theme = ExtResource("7_8lfnq")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"Now, channel enough power through a place, and it [i]becomes[/i] a Leyline--"

[node name="RichTextLabel4" type="RichTextLabel" parent="Leylines/Leyline"]
offset_left = 765.0
offset_top = 577.0
offset_right = 1495.0
offset_bottom = 697.0
theme = ExtResource("7_8lfnq")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "--which means you can now longer power the attatched electronics down,"

[node name="RichTextLabel5" type="RichTextLabel" parent="Leylines/Leyline"]
offset_left = 881.0
offset_top = 728.0
offset_right = 1600.0
offset_bottom = 840.0
theme = ExtResource("7_8lfnq")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "--or work on them without risking death by electrocution or Plague of Dreams, "

[node name="RichTextLabel6" type="RichTextLabel" parent="Leylines/Leyline"]
offset_left = 824.0
offset_top = 874.0
offset_right = 1543.0
offset_bottom = 1011.0
theme = ExtResource("7_8lfnq")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "--[i]and[/i] to top it off, the area is now at risk for Demon attacks!"

