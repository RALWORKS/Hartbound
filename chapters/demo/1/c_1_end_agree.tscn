texture = SubResource("ViewportTexture_4afen")

[node name="SmartLabel" parent="NoDisBelieves" index="3" instance=ExtResource("5_gpox3")]
offset_left = 0.0
offset_top = 829.0
offset_right = 1940.0
offset_bottom = 1009.0
bbcode_enabled = true
text = "\"When I said I don't feel at home in Sun Temple ... all that really means is that I haven't quite lost my sense of
being an outsider. I ... don't really follow the Elven ways anymore. Running away to Moon Temple is still
enticing somehow, but I would feel [i]much[/i] more out of place there than I do here. I have no doubt of it.\""
metadata/_edit_use_anchors_ = true

