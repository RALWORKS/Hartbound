[node name="SmartLabel" parent="NoHalfBelieves" index="3" instance=ExtResource("5_gpox3")]
offset_left = 0.0
offset_top = 829.0
offset_right = 1940.0
offset_bottom = 1009.0
bbcode_enabled = true
text = "\"I'm a little different from you <taylor>. I've settled a little more into the Human ways. Sun Temple isn't home.
But will Moon Temple be any different, now that I've been among humans for all these years? I need more time to
figure myself out before I can run off--[i]if[/i] I run off at all."
metadata/_edit_use_anchors_ = true

[node name="NoDisBelieves" parent="." index="15" instance=ExtResource("2_8b8lo")]

[node name="bg" type="Sprite2D" parent="NoDisBelieves" index="0"]
position = Vector2(-250, -74)
