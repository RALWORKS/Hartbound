[node name="taylor2" parent="NoDisBelieves" index="1" instance=ExtResource("4_fl887")]
position = Vector2(1205, 1696)
scale = Vector2(1.5, 1.5)

[node name="Profile" parent="NoDisBelieves" index="2" instance=ExtResource("9_1dapo")]
