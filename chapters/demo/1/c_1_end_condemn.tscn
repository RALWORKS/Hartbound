[node name="SmartLabel" parent="YesEnd" index="2" instance=ExtResource("5_1qq82")]
offset_left = 157.0
offset_top = 146.0
offset_right = 539.0
offset_bottom = 271.0
text = "\"I don't want to hear it, {taylor,calls_me}."

[node name="SmartLabel2" parent="YesEnd" index="3" instance=ExtResource("5_1qq82")]
offset_left = 341.0
offset_top = 296.0
offset_right = 656.0
offset_bottom = 421.0
text = "\"Thanks for the warning, I guess."

[node name="SmartLabel3" parent="YesEnd" index="4" instance=ExtResource("5_1qq82")]
offset_left = 1368.0
offset_top = 926.0
offset_right = 1573.0
offset_bottom = 1013.0
text = "\"Let's go.\""

[node name="No" parent="." index="11" node_paths=PackedStringArray("next") instance=ExtResource("2_e4o2s")]
