[node name="SmartLabel" parent="YesHalfBelieves" index="3" instance=ExtResource("5_1qq82")]
offset_left = 503.0
offset_top = 568.0
offset_right = 968.0
offset_bottom = 693.0
text = "\"I still have my ties to the ways of my people,"

[node name="SmartLabel2" parent="YesHalfBelieves" index="4" instance=ExtResource("5_1qq82")]
offset_left = 617.0
offset_top = 716.0
offset_right = 1318.0
offset_bottom = 841.0
bbcode_enabled = true
text = "\"But I am not such an ungrateful child as to shun the humans who raised us [i]both.[/i]\""

[node name="SmartLabel3" parent="YesHalfBelieves" index="5" instance=ExtResource("5_1qq82")]
offset_left = 4.0
offset_top = 861.0
offset_right = 1946.0
offset_bottom = 1082.0
bbcode_enabled = true
text = "\"Would Moon Temple take me, if I was deported? I don't know. I'm an  Elf, but I've wandered from the Way.
Did you stop and think about what would happen to me if you left, and the Secret Police suspected I'd known?
If you think they're suspicious of [i]Half-Elves[/i], imagine how they treat [i]me.[/i] If you wanted to leave, you should
have [i]kept that to yourself.[/i] Instead, you implicated me. And I have a lot to lose."

[node name="YesNoBelief" parent="." index="9" node_paths=PackedStringArray("next") instance=ExtResource("2_e4o2s")]
visible = false
next = NodePath("../YesEnd")

[node name="bg" type="Sprite2D" parent="YesNoBelief" index="0"]
