[node name="bg" type="Sprite2D" parent="No" index="0"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_f65xa")
centered = false

[node name="taylor" parent="No" index="1" instance=ExtResource("4_ecw63")]
position = Vector2(931, 848)
scale = Vector2(0.7, 0.7)

[node name="Profile" parent="No" index="2" instance=ExtResource("6_vfsqc")]
position = Vector2(-11, 104)
scale = Vector2(1.8, 1.8)
texture = SubResource("ViewportTexture_36ju6")
flip_h = true
with_background = false

[node name="SmartLabel3" parent="No" index="3" instance=ExtResource("5_1qq82")]
offset_left = -3.0
offset_top = 765.0
offset_right = 1929.0
offset_bottom = 851.0
text = "\"I'm not going to report you. I was never going to report you."

[node name="SmartLabel4" parent="No" index="4" instance=ExtResource("5_1qq82")]
offset_left = -3.0
offset_top = 862.0
offset_right = 1929.0
offset_bottom = 948.0
text = "\"But I want you to think about what it does to me if you leave, and it comes out somehow that I knew."

[node name="SmartLabel5" parent="No" index="5" instance=ExtResource("5_1qq82")]
offset_left = -3.0
offset_top = 959.0
offset_right = 1929.0
offset_bottom = 1101.0
bbcode_enabled = true
text = "\"They will ask, you know. I was close enough to you. And if you think they gave [i]you[/i] a hard time for your
heritage, imagine how it was for me.\""

[node name="NoSidesElves?" parent="." index="12" instance=ExtResource("11_2bv1v")]
visible = false
conditional_subject = "initially-sides-with-the-elves"

