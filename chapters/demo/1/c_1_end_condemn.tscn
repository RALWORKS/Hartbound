position = Vector2(977, 1607)
scale = Vector2(1.45072, 1.35)
texture = ExtResource("4_std1i")

[node name="Profile" parent="YesNoBelief" index="2" instance=ExtResource("6_vfsqc")]
modulate = Color(0, 0, 0, 1)
