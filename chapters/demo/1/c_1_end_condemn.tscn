[node name="SmartLabel" parent="YesFullyBelieves" index="3" instance=ExtResource("5_1qq82")]
offset_left = 516.0
offset_top = 61.0
offset_right = 970.0
offset_bottom = 186.0
text = "\"I pray to the same gods as you and seek the same ends. "

[node name="SmartLabel2" parent="YesFullyBelieves" index="4" instance=ExtResource("5_1qq82")]
offset_left = 520.0
offset_top = 205.0
offset_right = 1221.0
offset_bottom = 330.0
bbcode_enabled = true
text = "\"But I am not such an ungrateful child as to shun the humans who raised us [i]both.[/i]"

[node name="SmartLabel3" parent="YesFullyBelieves" index="5" instance=ExtResource("5_1qq82")]
offset_left = 589.0
offset_top = 595.0
offset_right = 1506.0
offset_bottom = 788.0
bbcode_enabled = true
text = "\"Betray the home of my birth, or the home that taught me my trade? It's not an easy position you've put me in, <taylor>. Did you stop and think about what would happen to me if you left, and the Secret Police suspected I'd known?
"

[node name="SmartLabel5" parent="YesFullyBelieves" index="6" instance=ExtResource("5_1qq82")]
offset_left = -10.0
offset_top = 810.0
offset_right = 1952.0
offset_bottom = 942.0
bbcode_enabled = true
text = "\"If you think they're suspicious of [i]Half-Elves[/i], imagine how they treat [i]me.[/i] If you wanted to leave, you should
have [i]kept that to yourself.[/i] Instead, you implicated me."

[node name="SmartLabel4" parent="YesFullyBelieves" index="7" instance=ExtResource("5_1qq82")]
offset_left = -10.0
offset_top = 964.0
offset_right = 1952.0
offset_bottom = 1096.0
bbcode_enabled = true
text = "\"Flee to Moon Temple with you, or rat you out. That's what my options collapse down to, if I want to
guarantee my own safety. You've [i]forced[/i] me to make a move. This is the move I'm choosing.\""

[node name="YesHalfBelieves" parent="." index="8" node_paths=PackedStringArray("next") instance=ExtResource("2_e4o2s")]
visible = false
