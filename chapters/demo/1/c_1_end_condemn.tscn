with_background = false

[node name="SmartLabel" parent="YesNoBelief" index="3" instance=ExtResource("5_1qq82")]
offset_left = 503.0
offset_top = 567.0
offset_right = 968.0
offset_bottom = 692.0
text = "\"I have long since left the ways of the Elves behind."

[node name="SmartLabel2" parent="YesNoBelief" index="4" instance=ExtResource("5_1qq82")]
offset_left = 573.0
offset_top = 714.0
offset_right = 1411.0
offset_bottom = 839.0
bbcode_enabled = true
text = "\"I would be even [i]more[/i] of a traitor if I stood silent while you turned your back on the people who raised us both.\""

[node name="SmartLabel3" parent="YesNoBelief" index="5" instance=ExtResource("5_1qq82")]
offset_left = 4.0
offset_top = 861.0
offset_right = 1946.0
offset_bottom = 1082.0
bbcode_enabled = true
text = "\"I have no home but Sun Temple, <taylor>, and you're putting my place here in jeopardy.
Did you stop and think about what would happen to me if you left, and the Secret Police suspected I'd known?
If you think they're suspicious of [i]Half-Elves[/i], imagine how they treat [i]me.[/i] If you wanted to leave, you should
have [i]kept that to yourself.[/i] Instead, you implicated me. What choice do I have now?"

[node name="YesEnd" parent="." index="10" instance=ExtResource("2_e4o2s")]
visible = false

