[node name="bg" type="Sprite2D" parent="NoNoBelief" index="0"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_f65xa")
centered = false

[node name="taylor" parent="NoNoBelief" index="1" instance=ExtResource("4_ecw63")]
position = Vector2(931, 848)
scale = Vector2(0.7, 0.7)

[node name="Profile" parent="NoNoBelief" index="2" instance=ExtResource("6_vfsqc")]
position = Vector2(-11, 104)
scale = Vector2(1.8, 1.8)
texture = SubResource("ViewportTexture_s87o3")
flip_h = true
with_background = false

[node name="SmartLabel3" parent="NoNoBelief" index="3" instance=ExtResource("5_1qq82")]
offset_left = -3.0
offset_top = 838.0
offset_right = 1927.0
offset_bottom = 962.0
text = "\"I don't follow the old ways--not the politics or the faith. My town is gone, and there's no place for me at
Moon Temple."

[node name="SmartLabel4" parent="NoNoBelief" index="4" instance=ExtResource("5_1qq82")]
offset_left = -3.0
offset_top = 974.0
offset_right = 1927.0
offset_bottom = 1060.0
text = "\"I'm risking the only home I have, keeping your secret. But I'll keep it. Please don't take that for granted.\""

[node name="NoSomeBelief" parent="." index="16" node_paths=PackedStringArray("next") instance=ExtResource("2_e4o2s")]
visible = false
next = NodePath("../NoEnd")

[node name="bg" type="Sprite2D" parent="NoSomeBelief" index="0"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_f65xa")
centered = false

[node name="taylor" parent="NoSomeBelief" index="1" instance=ExtResource("4_ecw63")]
position = Vector2(931, 848)
scale = Vector2(0.7, 0.7)

[node name="Profile" parent="NoSomeBelief" index="2" instance=ExtResource("6_vfsqc")]
position = Vector2(-11, 104)
scale = Vector2(1.8, 1.8)
texture = SubResource("ViewportTexture_kkal6")
flip_h = true
with_background = false

[node name="SmartLabel3" parent="NoSomeBelief" index="3" instance=ExtResource("5_1qq82")]
offset_left = -3.0
offset_top = 838.0
offset_right = 1927.0
offset_bottom = 989.0
text = "\"I've changed since I left home. I'm still an Elf, but I've taken some of the Human ways to heart. My town is
gone, and I don't know how readily Moon Temple would accept me as I am now. I know I have a place
here, for now ..."

[node name="SmartLabel4" parent="NoSomeBelief" index="4" instance=ExtResource("5_1qq82")]
offset_left = -3.0
offset_top = 1002.0
offset_right = 1927.0
offset_bottom = 1088.0
bbcode_enabled = true
text = "\"And I know I'm putting that at risk, keeping your secret. I [i]will[/i] keep it. But please don't take that for granted.\""

[node name="NoFullBelief" parent="." index="17" node_paths=PackedStringArray("next") instance=ExtResource("2_e4o2s")]
visible = false
next = NodePath("../NoEnd")

[node name="bg" type="Sprite2D" parent="NoFullBelief" index="0"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("3_f65xa")
centered = false

[node name="taylor" parent="NoFullBelief" index="1" instance=ExtResource("4_ecw63")]
position = Vector2(931, 848)
scale = Vector2(0.7, 0.7)

[node name="Profile" parent="NoFullBelief" index="2" instance=ExtResource("6_vfsqc")]
position = Vector2(-11, 104)
scale = Vector2(1.8, 1.8)
texture = SubResource("ViewportTexture_qxra0")
flip_h = true
with_background = false

[node name="SmartLabel3" parent="NoFullBelief" index="3" instance=ExtResource("5_1qq82")]
offset_left = -5.0
offset_top = 724.0
offset_right = 1925.0
offset_bottom = 850.0
text = "\"At the risk of committing my own act of treason ... you made the right guess about where my loyalties lie.
I am an Elf, after all, and my parents raised me well."

[node name="SmartLabel5" parent="NoFullBelief" index="4" instance=ExtResource("5_1qq82")]
offset_left = -5.0
offset_top = 864.0
offset_right = 1925.0
offset_bottom = 990.0
text = "\"When you leave, be careful about it--for my sake too. If you implicate me somehow, and they interrogate me ...
well, I have secrets of my own to keep. "

[node name="SmartLabel4" parent="NoFullBelief" index="5" instance=ExtResource("5_1qq82")]
offset_left = -3.0
offset_top = 1004.0
offset_right = 1927.0
offset_bottom = 1090.0
bbcode_enabled = true
text = "\"Keeping yours as well is no small ask. Don't take it for granted.\""

