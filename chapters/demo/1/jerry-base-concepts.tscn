[node name="RichTextLabel" type="RichTextLabel" parent="Medics/CutsceneNode"]
offset_left = 764.0
offset_top = 128.0
offset_right = 1189.0
offset_bottom = 218.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"You're not hurt, are you?"

[node name="RaiseToUILayer" parent="Medics/CutsceneNode/RichTextLabel" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel2" type="RichTextLabel" parent="Medics/CutsceneNode"]
offset_left = 869.0
offset_top = 241.0
offset_right = 1373.0
offset_bottom = 407.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"'Cause unless it's bad enough for medevac, I don't want you wasting Miss Taylor's time.\""

[node name="RaiseToUILayer" parent="Medics/CutsceneNode/RichTextLabel2" instance=ExtResource("8_mpvlo")]

[node name="Engineers" parent="." instance=ExtResource("15_jcbmt")]

[node name="Eng" parent="Engineers" instance=ExtResource("3_bfik8")]
visible = false

[node name="bg" type="Sprite2D" parent="Engineers/Eng"]
scale = Vector2(1.35, 1.35)
