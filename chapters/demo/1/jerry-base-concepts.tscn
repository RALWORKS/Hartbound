[node name="RichTextLabel" type="RichTextLabel" parent="Salvagers/sal1"]
offset_left = 764.0
offset_top = 148.0
offset_right = 1385.0
offset_bottom = 269.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"I've been salvaging since I was--well, younger than you, that's for sure."

[node name="RaiseToUILayer" parent="Salvagers/sal1/RichTextLabel" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel2" type="RichTextLabel" parent="Salvagers/sal1"]
offset_left = 846.0
offset_top = 292.0
offset_right = 1467.0
offset_bottom = 438.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"I plan on keeping it up 'til I can't. Then, the City'll take care of me, and I'll have a nice, long retirement.\""

[node name="RaiseToUILayer" parent="Salvagers/sal1/RichTextLabel2" instance=ExtResource("8_mpvlo")]

[node name="Medics" parent="." instance=ExtResource("14_mr4o6")]

[node name="CutsceneNode" parent="Medics" instance=ExtResource("3_bfik8")]
