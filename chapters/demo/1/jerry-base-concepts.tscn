offset_right = 1267.0
offset_bottom = 250.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"You're from ... 'Fun Sewn Leigh Hen?'"

[node name="RaiseToUILayer" parent="MyHometown/Default/RichTextLabel2" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel3" type="RichTextLabel" parent="MyHometown/Default"]
offset_left = 610.0
offset_top = 43.0
offset_right = 1050.0
offset_bottom = 127.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "Did I hear that right?"

[node name="RaiseToUILayer" parent="MyHometown/Default/RichTextLabel3" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel4" type="RichTextLabel" parent="MyHometown/Default"]
offset_left = 904.0
offset_top = 269.0
offset_right = 1415.0
offset_bottom = 407.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"Never heard of a place like that. I'd love to visit some day.\""

[node name="RaiseToUILayer" parent="MyHometown/Default/RichTextLabel4" instance=ExtResource("8_mpvlo")]

[node name="TellMeAboutYourself" parent="." instance=ExtResource("24_nk2q4")]

[node name="You" parent="TellMeAboutYourself" instance=ExtResource("3_bfik8")]
visible = false

[node name="bg" type="Sprite2D" parent="TellMeAboutYourself/You"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("4_rtvxf")
centered = false
script = ExtResource("5_lccoy")

[node name="jerry" type="Sprite2D" parent="TellMeAboutYourself/You"]
position = Vector2(455, 850)
scale = Vector2(0.7, 0.7)
texture = ExtResource("25_fjbjl")

[node name="RichTextLabel" type="RichTextLabel" parent="TellMeAboutYourself/You"]
offset_left = 748.0
offset_top = 136.0
offset_right = 1567.0
offset_bottom = 261.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"Sun Temple born and raised. Famiy legend is we've lived there since before the world ended."

[node name="RaiseToUILayer" parent="TellMeAboutYourself/You/RichTextLabel" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel2" type="RichTextLabel" parent="TellMeAboutYourself/You"]
offset_left = 972.0
offset_top = 292.0
offset_right = 1593.0
offset_bottom = 448.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"I've been training young guys like you for fifteen years, and yes, I know you're not an apprentice anymore."

[node name="RaiseToUILayer" parent="TellMeAboutYourself/You/RichTextLabel2" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel3" type="RichTextLabel" parent="TellMeAboutYourself/You"]
offset_left = 839.0
offset_top = 490.0
offset_right = 1545.0
offset_bottom = 657.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"But work in this world as long as I have, and anybody with less than ten years experience starts looking pretty green to you."

[node name="RaiseToUILayer" parent="TellMeAboutYourself/You/RichTextLabel3" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel4" type="RichTextLabel" parent="TellMeAboutYourself/You"]
offset_left = 847.0
offset_top = 685.0
offset_right = 1553.0
offset_bottom = 770.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"It'll make sense when you're older.\""

[node name="RaiseToUILayer" parent="TellMeAboutYourself/You/RichTextLabel4" instance=ExtResource("8_mpvlo")]

[node name="Brona" parent="." instance=ExtResource("26_7cdf2")]

[node name="brona" parent="Brona" instance=ExtResource("3_bfik8")]
visible = false

[node name="bg" type="Sprite2D" parent="Brona/brona"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("4_rtvxf")
centered = false
script = ExtResource("5_lccoy")

[node name="jerry" type="Sprite2D" parent="Brona/brona"]
position = Vector2(455, 850)
scale = Vector2(0.7, 0.7)
texture = ExtResource("25_fjbjl")

[node name="RichTextLabel" type="RichTextLabel" parent="Brona/brona"]
offset_left = 748.0
offset_top = 136.0
offset_right = 1567.0
offset_bottom = 261.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"She's smarter than she lets on, I tell you. A dumbass, for sure, but smart."

[node name="RaiseToUILayer" parent="Brona/brona/RichTextLabel" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel2" type="RichTextLabel" parent="Brona/brona"]
offset_left = 1000.0
offset_top = 276.0
offset_right = 1621.0
offset_bottom = 438.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"Thinking before she acts is a problem for her-- but for when she [i]does[/i] decide to use her brain, she's got a good one.\""

[node name="RaiseToUILayer" parent="Brona/brona/RichTextLabel2" instance=ExtResource("8_mpvlo")]

[node name="Nate" parent="." instance=ExtResource("27_kqmj6")]

[node name="nate" parent="Nate" instance=ExtResource("3_bfik8")]
