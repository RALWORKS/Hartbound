[node name="RichTextLabel" type="RichTextLabel" parent="EndOfTheWorld/endoftheworld"]
offset_left = 735.0
offset_top = 129.0
offset_right = 1236.0
offset_bottom = 280.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"My grandfather's grandfather lived to tell the tale."

[node name="RaiseToUILayer" parent="EndOfTheWorld/endoftheworld/RichTextLabel" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel2" type="RichTextLabel" parent="EndOfTheWorld/endoftheworld"]
offset_left = 837.0
offset_top = 304.0
offset_right = 1471.0
offset_bottom = 432.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"Demons coming out of the power lines. Dreams creeping into the waking world."

[node name="RaiseToUILayer" parent="EndOfTheWorld/endoftheworld/RichTextLabel2" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel3" type="RichTextLabel" parent="EndOfTheWorld/endoftheworld"]
offset_left = 911.0
offset_top = 457.0
offset_right = 1285.0
offset_bottom = 543.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"I can't even picture it."

[node name="RaiseToUILayer" parent="EndOfTheWorld/endoftheworld/RichTextLabel3" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel4" type="RichTextLabel" parent="EndOfTheWorld/endoftheworld"]
offset_left = 1027.0
offset_top = 559.0
offset_right = 1356.0
offset_bottom = 750.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"They say the only ones who can are those dying of the plague, bless them.\""

[node name="RaiseToUILayer" parent="EndOfTheWorld/endoftheworld/RichTextLabel4" instance=ExtResource("8_mpvlo")]

