[node name="RichTextLabel" type="RichTextLabel" parent="Nate/nate"]
offset_left = 748.0
offset_top = 136.0
offset_right = 1414.0
offset_bottom = 221.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"That young man has an attitude problem."

[node name="RaiseToUILayer" parent="Nate/nate/RichTextLabel" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel2" type="RichTextLabel" parent="Nate/nate"]
offset_left = 817.0
offset_top = 236.0
offset_right = 1438.0
offset_bottom = 370.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"He does [i]very[/i] good work, or I'd refuse to take him out on jobs, period."

[node name="RaiseToUILayer" parent="Nate/nate/RichTextLabel2" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel3" type="RichTextLabel" parent="Nate/nate"]
offset_left = 873.0
offset_top = 384.0
offset_right = 1655.0
offset_bottom = 543.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"But I'm retiring in the next few years, and whoever replaces me might not be so forgiving. That angry streak of Nate's might cost him his future.\""

[node name="RaiseToUILayer" parent="Nate/nate/RichTextLabel3" instance=ExtResource("8_mpvlo")]

[node name="Taylor" parent="." instance=ExtResource("29_so2c6")]

[node name="taylor" parent="Taylor" instance=ExtResource("3_bfik8")]
