[node name="bg" type="Sprite2D" parent="Leylines/Leyline"]
scale = Vector2(1.35, 1.35)
texture = ExtResource("4_rtvxf")
centered = false
script = ExtResource("5_lccoy")

[node name="jerry" type="Sprite2D" parent="Leylines/Leyline"]
position = Vector2(455, 850)
scale = Vector2(0.7, 0.7)
texture = ExtResource("25_fjbjl")

[node name="RichTextLabel" type="RichTextLabel" parent="Leylines/Leyline"]
offset_left = 714.0
offset_top = 81.0
offset_right = 1294.0
offset_bottom = 158.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
text = "\"Nasty things, Leylines."

[node name="RaiseToUILayer" parent="Leylines/Leyline/RichTextLabel" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel2" type="RichTextLabel" parent="Leylines/Leyline"]
offset_left = 796.0
offset_top = 177.0
offset_right = 1503.0
offset_bottom = 351.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
text = "\"You know, I was on a public works project one time that caused Leyline encroachment in a suburb of Sun Temple?"

[node name="RaiseToUILayer" parent="Leylines/Leyline/RichTextLabel2" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel3" type="RichTextLabel" parent="Leylines/Leyline"]
offset_left = 878.0
offset_top = 372.0
offset_right = 1608.0
offset_bottom = 495.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"They were trying to route a bit more power out there, and boom! Leyline takes the new grid."

[node name="RaiseToUILayer" parent="Leylines/Leyline/RichTextLabel3" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel4" type="RichTextLabel" parent="Leylines/Leyline"]
offset_left = 966.0
offset_top = 518.0
offset_right = 1696.0
offset_bottom = 638.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"They had to shut down the whole burrough and evacuate."

[node name="RaiseToUILayer" parent="Leylines/Leyline/RichTextLabel4" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel5" type="RichTextLabel" parent="Leylines/Leyline"]
offset_left = 898.0
offset_top = 657.0
offset_right = 1617.0
offset_bottom = 769.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"That's why there's all those blocked off roads at the edge of Burrough 76.\""

[node name="RaiseToUILayer" parent="Leylines/Leyline/RichTextLabel5" instance=ExtResource("8_mpvlo")]

[node name="HowAreYou" parent="." instance=ExtResource("22_4nux0")]

