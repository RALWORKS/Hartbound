[node name="RaiseToUILayer" parent="WhatDoYouThinkOfMe/me/RichTextLabel" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel2" type="RichTextLabel" parent="WhatDoYouThinkOfMe/me"]
