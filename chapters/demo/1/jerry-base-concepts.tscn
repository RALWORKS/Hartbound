[node name="RichTextLabel" type="RichTextLabel" parent="Sun Temple/SunTemple1"]
offset_left = 1.0
offset_top = 879.0
offset_right = 1946.0
offset_bottom = 999.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"My father was there when they named the place. Renamed it, I mean. They used to call it 'Tronno',
you know, but old language names like that just don't resonate with people these days.\""

[node name="RaiseToUILayer" parent="Sun Temple/SunTemple1/RichTextLabel" instance=ExtResource("8_mpvlo")]

[node name="Elves" parent="." instance=ExtResource("8_7wr3d")]

[node name="CutsceneNode" parent="Elves" instance=ExtResource("3_bfik8")]
