[node name="RichTextLabel" type="RichTextLabel" parent="Taylor/taylor"]
offset_left = 748.0
offset_top = 136.0
offset_right = 1142.0
offset_bottom = 221.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"I wish she'd smile more."

[node name="RaiseToUILayer" parent="Taylor/taylor/RichTextLabel" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel2" type="RichTextLabel" parent="Taylor/taylor"]
offset_left = 817.0
offset_top = 236.0
offset_right = 1551.0
offset_bottom = 509.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"You're not really supposed to say that about women anymore, I guess, but she goes around with this tired look all the time, and I'm never sure if it's just the 'careworn medic' thing, or if I oughta talk to the higher ups about getting her some more time off, you know?\""

[node name="RaiseToUILayer" parent="Taylor/taylor/RichTextLabel2" instance=ExtResource("8_mpvlo")]

