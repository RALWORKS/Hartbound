[node name="jerry" type="Sprite2D" parent="Engineers/Eng"]
position = Vector2(455, 850)
scale = Vector2(0.7, 0.7)
texture = ExtResource("28_mynp0")

[node name="RichTextLabel" type="RichTextLabel" parent="Engineers/Eng"]
offset_left = 776.0
offset_top = 215.0
offset_right = 1367.0
offset_bottom = 340.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
text = "\"Engineers, as a general rule, assume they know better than you do."

[node name="RaiseToUILayer" parent="Engineers/Eng/RichTextLabel" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel2" type="RichTextLabel" parent="Engineers/Eng"]
offset_left = 852.0
offset_top = 359.0
offset_right = 1505.0
offset_bottom = 558.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
text = "\"Doesn't matter when you've been in the field longer, or when you're working on something that they're just seeing for the first time in their life."

[node name="RaiseToUILayer" parent="Engineers/Eng/RichTextLabel2" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel3" type="RichTextLabel" parent="Engineers/Eng"]
offset_left = 906.0
offset_top = 577.0
offset_right = 1559.0
offset_bottom = 705.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
text = "\"Engineer knows best. It's a rule of the profession.\""

[node name="RaiseToUILayer" parent="Engineers/Eng/RichTextLabel3" instance=ExtResource("8_mpvlo")]

[node name="EndOfTheWorld" parent="." instance=ExtResource("16_ppoa1")]

[node name="endoftheworld" parent="EndOfTheWorld" instance=ExtResource("3_bfik8")]
