[node name="RichTextLabel2" type="RichTextLabel" parent="MoonTemple/CutsceneNode"]
offset_left = 717.0
offset_top = 84.0
offset_right = 1160.0
offset_bottom = 204.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"Why are you talking about Moon Temple?"

[node name="RaiseToUILayer" parent="MoonTemple/CutsceneNode/RichTextLabel2" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel3" type="RichTextLabel" parent="MoonTemple/CutsceneNode"]
offset_left = 812.0
offset_top = 227.0
offset_right = 1255.0
offset_bottom = 347.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"Aren't you from some small town near the border?"

[node name="RaiseToUILayer" parent="MoonTemple/CutsceneNode/RichTextLabel3" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel4" type="RichTextLabel" parent="MoonTemple/CutsceneNode"]
offset_left = 911.0
offset_top = 374.0
offset_right = 1354.0
offset_bottom = 494.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"You better not be planning anything.\""

[node name="RaiseToUILayer" parent="MoonTemple/CutsceneNode/RichTextLabel4" instance=ExtResource("8_mpvlo")]

[node name="Salvagers" parent="." instance=ExtResource("12_iypv4")]

[node name="sal1" parent="Salvagers" instance=ExtResource("3_bfik8")]
