[node name="RichTextLabel2" type="RichTextLabel" parent="HowAreYou/CutsceneNode"]
offset_left = 794.0
offset_top = 179.0
offset_right = 1154.0
offset_bottom = 274.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
text = "\"Oh, I'm gettin' on."

[node name="RaiseToUILayer" parent="HowAreYou/CutsceneNode/RichTextLabel2" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel3" type="RichTextLabel" parent="HowAreYou/CutsceneNode"]
offset_left = 851.0
offset_top = 295.0
offset_right = 1466.0
offset_bottom = 427.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
text = "\"Can't wait to get back home to the family--"

[node name="RaiseToUILayer" parent="HowAreYou/CutsceneNode/RichTextLabel3" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel4" type="RichTextLabel" parent="HowAreYou/CutsceneNode"]
offset_left = 820.0
offset_top = 445.0
offset_right = 1435.0
offset_bottom = 537.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
text = "\"Though it's fun out here with you kids."

[node name="RaiseToUILayer" parent="HowAreYou/CutsceneNode/RichTextLabel4" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel5" type="RichTextLabel" parent="HowAreYou/CutsceneNode"]
offset_left = 927.0
offset_top = 554.0
offset_right = 1542.0
offset_bottom = 680.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
text = "\"That Brona's gonna drive me to an early grave, bless her.\""

[node name="RaiseToUILayer" parent="HowAreYou/CutsceneNode/RichTextLabel5" instance=ExtResource("8_mpvlo")]

[node name="MyHometown" parent="." instance=ExtResource("23_xo6nt")]

