[node name="RichTextLabel" type="RichTextLabel" parent="Elves/CutsceneNode"]
offset_left = 742.0
offset_top = 148.0
offset_right = 1361.0
offset_bottom = 264.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
text = "\"Don't you ask me about Elves, now. I should be the one to ask you."

[node name="RaiseToUILayer" parent="Elves/CutsceneNode/RichTextLabel" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel2" type="RichTextLabel" parent="Elves/CutsceneNode"]
offset_left = 826.0
offset_top = 284.0
offset_right = 1446.0
offset_bottom = 364.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
text = "\"Is it true you're gonna live to be 200?\""

[node name="RaiseToUILayer" parent="Elves/CutsceneNode/RichTextLabel2" instance=ExtResource("8_mpvlo")]

[node name="Humans" parent="." instance=ExtResource("9_167hw")]

