[node name="RichTextLabel" type="RichTextLabel" parent="Humans/humans1"]
offset_left = 740.0
offset_top = 156.0
offset_right = 1142.0
offset_bottom = 244.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"Tell you about humans?"

[node name="RaiseToUILayer" parent="Humans/humans1/RichTextLabel" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel2" type="RichTextLabel" parent="Humans/humans1"]
offset_left = 907.0
offset_top = 254.0
offset_right = 1471.0
offset_bottom = 336.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"C'mon, buddy. You know about us."

[node name="RaiseToUILayer" parent="Humans/humans1/RichTextLabel2" instance=ExtResource("8_mpvlo")]

[node name="RichTextLabel3" type="RichTextLabel" parent="Humans/humans1"]
offset_left = 855.0
offset_top = 348.0
offset_right = 1349.0
offset_bottom = 467.0
theme = ExtResource("7_iu54m")
theme_type_variation = &"VoiceoverBox"
bbcode_enabled = true
text = "\"No long Elf lives. No weird Elf magic. Just normal. Human.\""

[node name="RaiseToUILayer" parent="Humans/humans1/RichTextLabel3" instance=ExtResource("8_mpvlo")]

[node name="MoonTemple" parent="." instance=ExtResource("10_ws3w1")]

