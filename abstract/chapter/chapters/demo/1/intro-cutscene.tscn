[node name="SmartLabel" parent="7" index="1" instance=ExtResource("7_67axm")]
offset_top = 243.0
offset_bottom = 977.0
bbcode_enabled = true
text = "You're at the halfway point of the work day. One solid afternoon's work, and you can make camp and put
your feet up. Then tomorrow, it's back to town, with all of its comforts.



[i]Objective:[/i]

Find someone to go salvaging with you this afternoon."

