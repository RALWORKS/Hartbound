[node name="ChoosePolitics" parent="." index="13" instance=ExtResource("2_tgpuw")]
visible = false
is_option_node = true

[node name="SmartLabel" parent="ChoosePolitics" index="0" instance=ExtResource("4_t01j7")]
offset_left = 111.0
offset_top = 167.0
offset_right = 1192.0
offset_bottom = 424.0
text = "But even aside from that, there's the politics of it.

Broadly, the Elves want to stamp out industrialization for good, while the Humans want to see it returned to its full glory.

As it stands now, on this issue, you side with ..."

[node name="Elves" parent="ChoosePolitics" index="1" node_paths=PackedStringArray("to") instance=ExtResource("9_02uum")]
offset_left = 144.0
offset_top = 464.0
offset_right = 544.0
offset_bottom = 512.0
text = "> The Elves"
to = NodePath("../../ElvesCheckPray")

[node name="InitiallySidesWithElves" parent="ChoosePolitics/Elves" index="1" instance=ExtResource("14_7vu0r")]

[node name="Humans" parent="ChoosePolitics" index="2" node_paths=PackedStringArray("to") instance=ExtResource("9_02uum")]
offset_left = 144.0
offset_top = 528.0
offset_right = 544.0
offset_bottom = 576.0
text = "> The Humans"
to = NodePath("../../HumansCheckPray")

[node name="InitiallySidesWithTheHumans" parent="ChoosePolitics/Humans" index="1" instance=ExtResource("15_xlw1i")]

[node name="PrayElves" parent="." index="14" instance=ExtResource("2_tgpuw")]
visible = false

[node name="SmartLabel" parent="PrayElves" index="0" instance=ExtResource("4_t01j7")]
offset_left = 136.0
offset_top = 452.0
offset_right = 1217.0
offset_bottom = 604.0
text = "It's only natural. As a Moon Sect adherent, there's no other way to look at it. The world has been out of balance for a long time. The healing that began when the Age of the Sun ended must reach its conclusion."

[node name="CogMind" type="Sprite2D" parent="PrayElves" index="1"]
position = Vector2(199, 925)
scale = Vector2(0.25, 0.25)
texture = ExtResource("13_wmcv2")

[node name="Title" parent="PrayElves" index="2" instance=ExtResource("4_t01j7")]
offset_left = 133.0
offset_top = 976.0
offset_right = 1374.0
offset_bottom = 1145.0
text = "Reflection recorded."

[node name="PrayHumans" parent="." index="15" instance=ExtResource("2_tgpuw")]
visible = false

[node name="SmartLabel" parent="PrayHumans" index="0" instance=ExtResource("4_t01j7")]
offset_left = 136.0
offset_top = 452.0
offset_right = 1217.0
offset_bottom = 676.0
bbcode_enabled = true
text = "Sometimes it's hard to look a fellow believer in the eye. The Moon Sect understands some [b]spiritual[/b] truth--but most of them have never [b]lived[/b] with electric light and central heating. You have, since you came to Sun Temple--and you can't bring yourself to pray that the children of the future will grow up in the dark."

[node name="CogMind" type="Sprite2D" parent="PrayHumans" index="1"]
position = Vector2(199, 925)
scale = Vector2(0.25, 0.25)
texture = ExtResource("13_wmcv2")

[node name="Title" parent="PrayHumans" index="2" instance=ExtResource("4_t01j7")]
offset_left = 133.0
offset_top = 976.0
offset_right = 1374.0
offset_bottom = 1145.0
text = "Reflection recorded."

[node name="NoPrayElves" parent="." index="16" instance=ExtResource("2_tgpuw")]
visible = false

[node name="SmartLabel" parent="NoPrayElves" index="0" instance=ExtResource("4_t01j7")]
offset_left = 136.0
offset_top = 452.0
offset_right = 1217.0
offset_bottom = 676.0
bbcode_enabled = true
text = "You don't have to be religious to see the damage that the Great Age of Humanity did to the planet.

Industrialization had its chance. That's over now."

[node name="CogMind" type="Sprite2D" parent="NoPrayElves" index="1"]
position = Vector2(199, 925)
scale = Vector2(0.25, 0.25)
texture = ExtResource("13_wmcv2")

[node name="Title" parent="NoPrayElves" index="2" instance=ExtResource("4_t01j7")]
offset_left = 133.0
offset_top = 976.0
offset_right = 1374.0
offset_bottom = 1145.0
text = "Reflection recorded."

[node name="NoPrayHumans" parent="." index="17" instance=ExtResource("2_tgpuw")]
visible = false

[node name="SmartLabel" parent="NoPrayHumans" index="0" instance=ExtResource("4_t01j7")]
offset_left = 136.0
offset_top = 452.0
offset_right = 1217.0
offset_bottom = 676.0
bbcode_enabled = true
text = "Of course you side with the Humans. You've seen Sun Temple. You've experienced the marvels of central heating and electric light. Why, aside from Moon Sect dogma, would anyone want to damn the children of the future to a life in the dark?"

[node name="CogMind" type="Sprite2D" parent="NoPrayHumans" index="1"]
position = Vector2(199, 925)
scale = Vector2(0.25, 0.25)
texture = ExtResource("13_wmcv2")

[node name="Title" parent="NoPrayHumans" index="2" instance=ExtResource("4_t01j7")]
offset_left = 133.0
offset_top = 976.0
offset_right = 1374.0
offset_bottom = 1145.0
text = "Reflection recorded."

[node name="IDKElves" parent="." index="18" instance=ExtResource("2_tgpuw")]
visible = false

[node name="SmartLabel" parent="IDKElves" index="0" instance=ExtResource("4_t01j7")]
offset_left = 136.0
offset_top = 452.0
offset_right = 1217.0
offset_bottom = 676.0
bbcode_enabled = true
text = "Of course you do.
You haven't turned your back on the teachings of your people entirely--you just have a more complex perspective now."

[node name="CogMind" type="Sprite2D" parent="IDKElves" index="1"]
position = Vector2(199, 925)
scale = Vector2(0.25, 0.25)
texture = ExtResource("13_wmcv2")

[node name="Title" parent="IDKElves" index="2" instance=ExtResource("4_t01j7")]
offset_left = 133.0
offset_top = 976.0
offset_right = 1374.0
offset_bottom = 1145.0
text = "Reflection recorded."

[node name="IDKHumans" parent="." index="19" instance=ExtResource("2_tgpuw")]

[node name="SmartLabel" parent="IDKHumans" index="0" instance=ExtResource("4_t01j7")]
offset_left = 136.0
offset_top = 452.0
offset_right = 1217.0
offset_bottom = 676.0
bbcode_enabled = true
text = "You're not sure where you stand with regard to religious belief, but your time with the humans has taught you better than to shun industrialization outright. Warmth in the winter and light in the dark are things everyone should have."

[node name="CogMind" type="Sprite2D" parent="IDKHumans" index="1"]
position = Vector2(199, 925)
scale = Vector2(0.25, 0.25)
texture = ExtResource("13_wmcv2")

