[sub_resource type="GDScript" id="GDScript_kldhx"]
script/source = "extends Node2D

@export var spawn_at = \"s\"
@export var contents_node: Node2D
@export var vein_node: Node

var LeylineScreen = preload(\"res://effects/leyline_screen.tscn\")


# Called when the node enters the scene tree for the first time.
func _ready():
	if vein_node:
		vein_node.visible = false
	add_chapter_contents()
	leyline()

func leyline():
	var ley = LeylineScreen.instantiate()
	ley.set_vein_node(vein_node)
	add_child(ley)
	move_child(ley, $YSort.get_index())
	ley.run(self)

# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(_delta):
	pass
	
func _duplicate(n):
	var scn = load(n.scene_file_path)
	var d = scn.instantiate()
	var props = n.get_property_list()
	for i in props.size():
		var attr = props[i].name
		if attr in [
			\"multiplayer\",
			\"owner\",
		]:
			continue
		if attr not in d or attr not in n:
			continue
		d[attr] = n[attr]
	return d
	

func add_chapter_contents():
	if contents_node:
		contents_node.visible = false
		for child in contents_node.get_children():
			var item = _duplicate(child)
#			item.set_owner($YSort)
			#item.visible = true
#			item.get_parent().remove_child(item)
			$YSort.add_child(item)
			child.process_mode = Node.PROCESS_MODE_DISABLED
			item.process_mode = Node.PROCESS_MODE_INHERIT
			assert(item.process_mode != child.process_mode)

func spawn(g):
	#$TileMap/DefaultSpawner.spawn()
#	$YSort/DefaultSpawner.spawn()
	$YSort/DefaultSpawner.spawn(g)
"

