theme_override_font_sizes/normal_font_size = 30
text = "Elven names are generally a sentence or sentence fragment, often a reference to mythology or spritituality.

Most elves use a  short form of their name for day to day interactions, with the full form only being used in formal situations."

[node name="ElvenNameText2" type="RichTextLabel" parent="2_5" index="4"]
offset_left = 60.0
offset_top = 84.0
offset_right = 988.0
offset_bottom = 217.0
theme_type_variation = &"VoiceoverBox"
theme_override_font_sizes/normal_font_size = 30
text = "The Elves teach that names are powerful--that the name of each thing is a prayer. You may go by another name now, after years among the humans, but"

